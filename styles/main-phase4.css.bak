/* ═══════════════════════════════════════════════════════════════
   RETIREMENT PLANNER — Main Stylesheet
   Structure: Tokens → Base → Layout → Components → Pages → Print
   ═══════════════════════════════════════════════════════════════ */


/* ═══════════════════════════════════════════════════════════════
   0 · TOKENS
   ═══════════════════════════════════════════════════════════════ */
:root {
  /* Legacy structural tokens (consumed by base components) */
  --bg: #eef3f8;
  --panel: #ffffff;
  --panel2: #f8fafc;
  --text: #0f172a;
  --muted: #64748b;
  --brand: #2563eb;
  --brand2: #14b8a6;
  --good: #16a34a;
  --warn: #d97706;
  --bad: #dc2626;
  --line: rgba(15,23,42,.12);
  --shadow: 0 16px 40px rgba(15,23,42,.10);
  --radius: 16px;
  --sans: "Avenir Next","Segoe UI","SF Pro Text",system-ui,-apple-system,Helvetica,Arial,sans-serif;
  --serif: "Iowan Old Style","Palatino Linotype",Palatino,"Times New Roman",serif;

  /* Clarity-first theme tokens */
  --apple-bg: #f3f5f9;
  --apple-bg-soft: #eef2f8;
  --apple-surface: #ffffff;
  --apple-surface-2: #f8fafe;
  --apple-border: rgba(15,23,42,.10);
  --apple-border-strong: rgba(15,23,42,.16);
  --apple-text: #0f172a;
  --apple-text-soft: #334155;
  --apple-text-muted: #64748b;
  --apple-accent: #2563eb;
  --apple-accent-soft: #dbeafe;
  --apple-good: #15803d;
  --apple-good-bg: #ecfdf3;
  --apple-warn: #b45309;
  --apple-warn-bg: #fff7ed;
  --apple-bad: #be123c;
  --apple-bad-bg: #fff1f2;
  --apple-shadow: 0 10px 28px rgba(15,23,42,.08);

  /* Interaction tokens */
  --dur: .16s;
  --dur-fast: .12s;
  --focus-ring: 0 0 0 3px rgba(37,99,235,.14);

  /* Mobile safe-area */
  --safeBottom: env(safe-area-inset-bottom);
}


/* ═══════════════════════════════════════════════════════════════
   1 · BASE  —  Reset, body, typography, form elements, tables
   ═══════════════════════════════════════════════════════════════ */
* { box-sizing: border-box; }

body {
  margin: 0;
  font-family: "SF Pro Text","Avenir Next","Segoe UI",Helvetica,Arial,sans-serif;
  color: var(--apple-text) !important;
  background:
    radial-gradient(1100px 620px at 8% -8%, rgba(37,99,235,.13), transparent 62%),
    radial-gradient(860px 460px at 96% -14%, rgba(14,165,233,.10), transparent 62%),
    linear-gradient(180deg, #f8fbff 0%, var(--apple-bg) 100%) !important;
}

label { font-size: 12px; color: var(--muted); }

input, select, textarea {
  padding: 10px; border-radius: 12px; outline: none;
  background: #ffffff !important;
  color: var(--apple-text) !important;
  border: 1px solid rgba(15,23,42,.14) !important;
}
input:focus, select:focus, textarea:focus {
  border-color: rgba(37,99,235,.45) !important;
  box-shadow: var(--focus-ring) !important;
}

table { width: 100%; border-collapse: collapse; font-size: 13px; }
th, td { padding: 10px; text-align: left; }
th {
  font-weight: 600;
  color: var(--apple-text-muted) !important;
  background: #f8fafc !important;
  border-bottom: 1px solid rgba(15,23,42,.10) !important;
}
td {
  color: var(--apple-text-soft) !important;
  border-bottom: 1px solid rgba(15,23,42,.08) !important;
}
tbody tr:hover td { background: #f8fbff !important; }

.muted { color: var(--muted); }
.small { font-size: 12px; }
.right { text-align: right; }


/* ═══════════════════════════════════════════════════════════════
   2 · LAYOUT  —  App grid, sidebar, topbar, content, bottom nav
   ═══════════════════════════════════════════════════════════════ */

/* ── App shell (mobile-first) ── */
.app { display: grid; grid-template-columns: 1fr; min-height: 100vh; }

/* ── Sidebar (mobile: off-canvas drawer) ── */
.sidebar {
  position: fixed; top: 0; left: 0; height: 100vh;
  width: 320px; max-width: 86vw; z-index: 60;
  transform: translateX(-105%); transition: transform .22s ease;
  overflow: auto; padding: 18px 16px 24px;
  background: linear-gradient(180deg, #1a1f2e 0%, #0f1419 100%) !important;
  border-right: 1px solid rgba(255,255,255,.08) !important;
  backdrop-filter: blur(18px);
}
body.navOpen .sidebar { transform: translateX(0); }
#sideOverlay {
  position: fixed; inset: 0; background: rgba(0,0,0,.55);
  z-index: 55; display: none;
}
body.navOpen #sideOverlay { display: block; }

.sidebar .hr { background: rgba(255,255,255,.08) !important; }
.sidebar .small.muted { color: #8b96ad !important; }

/* ── Brand ── */
.brand {
  display: flex; gap: 10px; align-items: center;
  border-bottom: none !important;
  padding: 12px 10px 10px !important;
}
.brand-copy { min-width: 0; }
.brand-tagline {
  color: #60a5fa !important;
  font-size: 11px; font-weight: 700; font-style: italic;
  letter-spacing: .02em; padding: 4px 10px 0;
}
.logo {
  width: 46px !important; height: 46px !important;
  border-radius: 14px !important;
  background: linear-gradient(135deg, #2563eb 0%, #06b6d4 100%) !important;
  box-shadow: 0 8px 20px rgba(37,99,235,.30) !important;
}
.brand h1 {
  font-family: var(--serif); font-weight: 700;
  letter-spacing: .01em; margin: 0;
  color: #ffffff !important; font-size: 20px !important;
}
.brand p {
  margin: 0; letter-spacing: .07em; text-transform: uppercase;
  color: #7c8aa9 !important; font-size: 10px !important;
}

/* ── Rail controls ── */
.rail-head { display: none; }
.rail-toggle {
  all: unset; cursor: pointer; width: 32px; height: 32px;
  border-radius: 10px; display: inline-flex;
  align-items: center; justify-content: center; font-size: 14px;
  transition: background-color var(--dur) ease, border-color var(--dur) ease, color var(--dur) ease;
  background: rgba(255,255,255,.08) !important;
  border-color: rgba(255,255,255,.12) !important;
  color: #a0aec0 !important;
}
.rail-toggle:hover {
  background: rgba(255,255,255,.14) !important;
  color: #e2e8f0 !important;
}
.rail-toggle:focus-visible { outline: none; box-shadow: var(--focus-ring); }

.rail-quick {
  display: grid; grid-template-columns: repeat(3,minmax(0,1fr));
  margin: 6px 0 14px !important; gap: 6px !important;
}
.rail-quick .btn {
  font-size: 11px !important; text-align: center;
  font-weight: 600 !important; letter-spacing: .01em;
  background: rgba(255,255,255,.06) !important;
  border: 1px solid rgba(255,255,255,.12) !important;
  color: #cbd5e1 !important;
  border-radius: 999px !important;
  padding: 8px 10px !important;
  transition: background-color var(--dur) ease, border-color var(--dur) ease;
}
.rail-quick .btn:hover {
  background: rgba(255,255,255,.12) !important;
  border-color: rgba(255,255,255,.20) !important;
  color: #ffffff !important;
}

/* ── Navigation ── */
.nav { margin-top: 12px; display: grid; gap: 16px !important; }
.nav-group {
  display: grid;
  background: rgba(255,255,255,.04) !important;
  border: 1px solid rgba(255,255,255,.06) !important;
  border-radius: 14px !important;
  padding: 10px 8px !important;
  gap: 4px !important;
}
.nav-group-title {
  color: #ffffff !important;
  font-size: 14px !important; font-weight: 700 !important;
  letter-spacing: .01em !important;
  text-transform: none !important;
  padding: 2px 4px 6px !important;
}
.nav button {
  all: unset; cursor: pointer; border-radius: 12px;
  display: flex; justify-content: space-between; align-items: center;
  gap: 8px; border: 1px solid transparent; position: relative;
  transition: background-color var(--dur) ease, border-color var(--dur) ease,
              transform var(--dur) ease, box-shadow var(--dur) ease;
  color: #e2e8f0 !important; padding: 11px 12px !important;
}
.nav button::before {
  content: ''; position: absolute; left: 0; top: 7px; bottom: 7px;
  width: 3px; border-radius: 2px; background: transparent;
}
.nav button:hover {
  background: rgba(59,130,246,.14) !important;
  border-color: transparent !important;
  transform: translateX(1px);
}
.nav button:focus-visible { outline: none; box-shadow: 0 0 0 3px rgba(59,130,246,.24); }
.nav button.active {
  background: rgba(59,130,246,.18) !important;
  border-color: rgba(59,130,246,.35) !important;
  color: #ffffff !important;
}
.nav button.active::before { background: #3b82f6 !important; }

.nav-main { display: flex; align-items: center; gap: 9px; min-width: 0; }
.nav-ico {
  display: inline-flex; align-items: center; justify-content: center;
  text-align: center; font-weight: 700; letter-spacing: .03em;
  transition: transform var(--dur) ease, border-color var(--dur) ease, background-color var(--dur) ease;
  background: rgba(255,255,255,.08) !important;
  border: 1px solid rgba(255,255,255,.10) !important;
  border-radius: 50% !important;
  width: 28px !important; height: 28px !important;
  color: #94a3b8 !important; font-size: 14px !important;
}
.nav button:hover .nav-ico { transform: scale(1.03); color: #cbd5e1 !important; }
.nav button.active .nav-ico {
  background: rgba(59,130,246,.20) !important;
  border-color: rgba(59,130,246,.40) !important;
  color: #60a5fa !important;
}
.nav-label {
  font-size: 15px !important; font-weight: 500 !important;
  white-space: nowrap; letter-spacing: -.01em;
}
.nav-meta { margin-left: auto; display: flex; align-items: center; gap: 8px; }
.pill { display: none !important; }
.nav-dot { display: none !important; }

/* ── Content area ── */
.content { padding: 16px; padding-bottom: 92px; max-width: none; margin: 0; width: 100%; }

/* Muted-text mega-selector */
.content .muted, .content .small, .footer, label, .hint,
.overview-summary-detail, .overview-breakdown-label,
.overview-next-step-text, .overview-watchout-text,
.projection-help-text, .projection-note-line,
.strategy-table-summary,
.validation-item-type, .validation-item-msg {
  color: var(--apple-text-muted) !important;
}

/* ── Topbar ── */
.topbar {
  display: flex; flex-wrap: wrap; gap: 10px;
  align-items: center; justify-content: space-between;
  position: sticky; top: 0; z-index: 30; margin-bottom: 12px;
  -webkit-backdrop-filter: blur(16px);
  background: rgba(255,255,255,.82) !important;
  border: 1px solid rgba(15,23,42,.06) !important;
  border-radius: 16px !important;
  box-shadow: 0 4px 16px rgba(15,23,42,.06), 0 1px 3px rgba(15,23,42,.04);
  backdrop-filter: blur(20px);
  padding: 12px 16px !important;
}
.topbar h2 {
  margin: 0; font-family: var(--serif);
  font-size: 24px !important; font-weight: 700 !important;
  letter-spacing: -.02em !important;
  color: var(--apple-text) !important;
}
.topbar-leading, .topbar-trailing,
.workspace-status, .topbar-context { display: flex; align-items: center; }
.topbar-leading { gap: 12px; min-width: 0; }
.topbar-context { flex-direction: column; align-items: flex-start; gap: 2px; }
.topbar-trailing { margin-left: auto; gap: 14px; justify-content: flex-end; flex-wrap: wrap; }
.workspace-status { gap: 8px; flex-wrap: wrap; }
.topbar-eyebrow {
  color: #64748b !important; font-size: 10px !important;
  font-weight: 700 !important; letter-spacing: .12em !important;
  text-transform: uppercase;
}
.workspace-chip {
  display: inline-flex; align-items: center; white-space: nowrap;
  min-height: 30px !important; border-radius: 999px !important;
  font-size: 11px !important; font-weight: 600 !important;
  padding: 0 12px !important;
  border: 1px solid rgba(15,23,42,.08);
  background: rgba(255,255,255,.86); color: #334155;
}
.workspace-chip--plan {
  background: rgba(239,246,255,.92) !important;
  border-color: rgba(37,99,235,.18) !important;
  color: #2563eb !important;
}
#freshnessBadge {
  border-radius: 999px !important; font-size: 11px !important;
  padding: 4px 12px !important;
  background: rgba(255,255,255,.9) !important;
  border: 1px solid rgba(15,23,42,.08) !important;
}
.actions { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
.menuBtn {
  display: inline-flex; align-items: center; justify-content: center;
  padding: 10px 12px; border-radius: 14px; font-size: 18px; font-weight: 700;
}

/* ── Bottom nav (mobile) ── */
.bottomNav {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 45;
  display: grid; grid-template-columns: repeat(8,1fr); gap: 6px;
  padding: 10px 10px calc(10px + var(--safeBottom));
  background: rgba(248,251,255,.95); border-top: 1px solid var(--line);
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
}
.bottomNav button {
  all: unset; cursor: pointer; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 4px;
  padding: 10px 6px; border-radius: 14px;
  border: 1px solid transparent; font-size: 11px; color: #334155;
  transition: background-color var(--dur) ease, border-color var(--dur) ease, transform var(--dur) ease;
}
.bottomNav button span { font-size: 10.5px; color: #64748b; }
.bottomNav button:hover { background: rgba(59,130,246,.06); }
.bottomNav button:focus-visible { outline: none; box-shadow: var(--focus-ring); }
.bottomNav button.active {
  background: rgba(59,130,246,.10); border-color: rgba(59,130,246,.28);
}
.bnav-ico {
  width: 20px; height: 20px; border-radius: 7px;
  border: 1px solid rgba(37,99,235,.2);
  background: linear-gradient(180deg, rgba(239,246,255,.9), rgba(219,234,254,.85));
  color: #1d4ed8; font-size: 9px; font-weight: 700;
  display: inline-flex; align-items: center; justify-content: center;
  transition: transform var(--dur) ease, border-color var(--dur) ease;
}
.bottomNav button:hover .bnav-ico { transform: scale(1.03); border-color: rgba(37,99,235,.34); }

/* Mobile action visibility */
.actions > button:not(#btnRecalc):not(#btnActions) { display: none; }
#btnActions { display: inline-flex; }

/* ── Action sheet & command palette ── */
.sheet { position: fixed; inset: 0; background: rgba(15,23,42,.36); display: none; z-index: 80; }
.sheet[aria-hidden="false"] { display: block; }
.sheetPanel {
  position: absolute; left: 0; right: 0; bottom: 0;
  background: rgba(255,255,255,.98); border-top: 1px solid var(--line);
  border-radius: 18px 18px 0 0; padding: 14px; box-shadow: var(--shadow);
}
.sheetHeader { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
.sheetTitle { font-weight: 800; }
.sheetGrid { display: grid; grid-template-columns: repeat(2,1fr); gap: 10px; margin-top: 12px; }

.cmdPanel {
  max-width: 680px; margin: 0 auto 6vh; border-radius: 16px;
  border: 1px solid rgba(59,130,246,.22); background: rgba(255,255,255,.98);
}
.cmdInput {
  width: 100%; margin-top: 10px;
  padding: 10px 12px; border-radius: 12px; outline: none;
  background: rgba(248,250,252,.92); border: 1px solid var(--line); color: var(--text);
}
.cmdList { margin-top: 10px; display: grid; gap: 7px; max-height: 46vh; overflow: auto; }
.cmdItem {
  all: unset; cursor: pointer; border: 1px solid var(--line);
  border-radius: 12px; padding: 9px 10px; display: flex;
  justify-content: space-between; align-items: center; gap: 10px;
  background: rgba(255,255,255,.92);
  transition: border-color var(--dur) ease, background-color var(--dur) ease;
}
.cmdItem:hover, .cmdItem.active { border-color: rgba(59,130,246,.30); background: rgba(59,130,246,.10); }
.cmdItem:focus-visible { outline: none; box-shadow: var(--focus-ring); }
.cmdItemLabel { font-weight: 600; }
.cmdItemHint { font-size: 11px; color: var(--muted); }
.cmdItemKbd {
  font-size: 10px; color: var(--muted);
  border: 1px solid var(--line); border-radius: 6px; padding: 2px 6px;
}

/* ── Desktop (≥ 981 px) ── */
@media (min-width: 981px) {
  .app { grid-template-columns: 280px minmax(0,1fr); column-gap: 0; }
  .sidebar {
    position: sticky; top: 0; width: 280px; min-width: 280px;
    transform: none; height: 100vh; z-index: 2;
    overflow: auto; padding: 12px 12px 18px;
  }
  .rail-head { display: flex; justify-content: flex-end; margin-bottom: 8px; }
  .brand { padding: 8px 10px 12px; }
  .rail-quick { margin: 10px 0 10px; }
  .nav { gap: 12px; }
  .nav-group { gap: 6px; }
  .content { padding: 16px 20px 22px; }
  #sideOverlay { display: none !important; }
  .menuBtn { display: none; }
  .bottomNav { display: none; }
  .actions > button { display: inline-flex; }
  #btnActions { display: none; }
  .topbar { position: sticky; top: 12px; z-index: 20; margin-bottom: 12px; }
  .svgwrap svg { min-width: 0; width: 100%; height: auto; }

  /* Rail collapse */
  body.railCollapsed .app { grid-template-columns: 88px minmax(0,1fr) !important; }
  body.railCollapsed .sidebar {
    width: 88px; min-width: 88px;
    padding-left: 10px; padding-right: 10px;
  }
  body.railCollapsed .brand { justify-content: center; }
  body.railCollapsed .brand-copy,
  body.railCollapsed .nav-group-title,
  body.railCollapsed .nav-label,
  body.railCollapsed .nav-meta,
  body.railCollapsed .rail-quick,
  body.railCollapsed .sidebar .hr,
  body.railCollapsed .sidebar .small.muted { display: none; }
  body.railCollapsed .nav button { justify-content: center; padding: 10px 8px; }
  body.railCollapsed .nav-main { justify-content: center; width: 100%; }
  body.railCollapsed .nav-ico { width: 28px; height: 28px; }
  body.railCollapsed .content { padding-left: 24px; padding-right: 28px; }
}


/* ═══════════════════════════════════════════════════════════════
   3 · COMPONENTS  —  Buttons, cards, badges, forms, charts, etc.
   ═══════════════════════════════════════════════════════════════ */

/* ── Buttons ── */
.btn {
  cursor: pointer; padding: 8px 10px; border-radius: 12px; font-size: 13px;
  transition: border-color var(--dur) ease, background-color var(--dur) ease,
              transform var(--dur) ease, box-shadow var(--dur) ease;
  background: var(--apple-surface) !important;
  color: var(--apple-text-soft) !important;
  border: 1px solid var(--apple-border) !important;
  box-shadow: 0 3px 10px rgba(15,23,42,.05);
}
.btn:hover {
  background: var(--apple-surface-2) !important;
  border-color: rgba(37,99,235,.28) !important;
  color: var(--apple-text) !important;
}
.btn.primary {
  border-radius: 999px !important;
  padding: 8px 18px !important;
  font-weight: 650 !important;
}
.btn.primary,
.tabs button.active,
.bottomNav button.active {
  background: linear-gradient(135deg, #2563eb, #0ea5e9) !important;
  color: #f8fbff !important;
  border-color: rgba(37,99,235,.55) !important;
  box-shadow: 0 10px 22px rgba(37,99,235,.28) !important;
}
.btn:active { transform: translateY(1px); }
.btn:focus-visible { outline: none; box-shadow: var(--focus-ring); }
.btn[disabled] { opacity: .55; cursor: not-allowed; }

/* ── Grid & cards ── */
.grid { display: grid; grid-template-columns: repeat(12,1fr); gap: 14px; }
.card {
  grid-column: span 12; border-radius: var(--radius); padding: 14px;
}
.card h3 { margin: 0 0 8px; font-size: 14px; letter-spacing: .2px; }
.topbar h2, .card h3, .card h4 { color: var(--apple-text) !important; }

/* Card / panel / shell – unified surface treatment */
:is(.card, .overview-panel, .stress-panel, .monte-panel,
  .projection-table-shell, .strategy-table-shell,
  .strategy-context-callout, .strategy-watchouts-shell,
  .strategy-explainer-shell, .strategy-explainer-item,
  .strategy-watchout-item, .strategy-timeline-card,
  .overview-breakdown-item, .overview-watchout,
  .overview-bridge-summary, .overview-change-item,
  .projection-row-detail-card, .projection-row-detail-item,
  .stress-advanced-details, .monte-advanced-details,
  .helpAcc, .validation-item, .validation-info,
  .callout, .repeatCard, .repeatEmpty) {
  background: linear-gradient(180deg, rgba(255,255,255,.98), rgba(248,251,255,.96)) !important;
  border: 1px solid var(--apple-border) !important;
  color: var(--apple-text-soft) !important;
  box-shadow: var(--apple-shadow) !important;
}

/* KPI / value-cards – flat white */
:is(.kpi .k, .strategy-kpi-item, .overview-summary-card,
  .projection-summary-card, .stress-outcome-card,
  .monte-outcome-card, .bridge-kpi) {
  background: #ffffff !important;
  border: 1px solid rgba(15,23,42,.08) !important;
  box-shadow: 0 1px 3px rgba(15,23,42,.06), 0 6px 16px rgba(15,23,42,.04) !important;
}

/* KPI labels */
.k .label, .strategy-kpi-item .label,
.overview-summary-label, .projection-summary-label,
.projection-summary-kpi-label, .monte-outcome-label,
.stress-outcome-label, .bridge-kpi .label {
  color: var(--apple-text-muted) !important;
  font-size: 11px; letter-spacing: .04em;
  text-transform: uppercase; font-weight: 650;
}
/* KPI values */
.k .value, .strategy-kpi-item .value,
.overview-summary-value, .projection-summary-age,
.projection-age-value, .monte-outcome-value,
.stress-outcome-value, .bridge-kpi .value {
  color: var(--apple-text) !important;
  font-weight: 650 !important;
  letter-spacing: -.01em !important;
}

/* ── KPI strip ── */
.kpi { display: grid; grid-template-columns: repeat(12,1fr); gap: 12px; }
.kpi .k { grid-column: span 3; border-radius: 14px; padding: 12px; }
@media (max-width: 980px) { .kpi .k { grid-column: span 6; } }
@media (max-width: 560px) { .kpi .k { grid-column: span 12; } }
.k .label { color: var(--muted); font-size: 12px; }
.k .value { font-size: 18px; margin-top: 6px; }

/* ── Forms ── */
.form { display: grid; grid-template-columns: repeat(12,1fr); gap: 10px; }
.field { grid-column: span 4; display: flex; flex-direction: column; gap: 6px; }
.field.w6 { grid-column: span 6; }
.field.w12 { grid-column: span 12; }
@media (max-width: 980px) { .field { grid-column: span 6; } }
@media (max-width: 560px) { .field { grid-column: span 12; } }
.row { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }

/* ── Badges ── */
.badge {
  font-size: 12px; padding: 4px 10px; border-radius: 999px;
  display: inline-flex; align-items: center; gap: 7px;
  background: #f8fafc !important;
  border: 1px solid var(--apple-border) !important;
  color: var(--apple-text-soft) !important;
}
.badge .ico {
  display: inline-flex; width: 16px; height: 16px;
  align-items: center; justify-content: center;
  border-radius: 6px; font-weight: 700; font-size: 12px;
  background: var(--apple-accent-soft) !important;
  color: #1d4ed8 !important;
}
.badge.good, .badge.ok {
  background: var(--apple-good-bg) !important;
  border-color: rgba(21,128,61,.34) !important;
  color: var(--apple-good) !important;
}
.badge.warn {
  background: var(--apple-warn-bg) !important;
  border-color: rgba(180,83,9,.34) !important;
  color: var(--apple-warn) !important;
}
.badge.bad {
  background: var(--apple-bad-bg) !important;
  border-color: rgba(190,18,60,.34) !important;
  color: var(--apple-bad) !important;
}
.badge.na {
  border-color: rgba(148,163,184,.36);
  background: rgba(255,255,255,.7);
  color: #475569;
}

/* Pill / chip / legend shared treatment */
.pill, .projection-event-chip, .projection-legend-chip,
.stress-legend-chip, .stress-chip {
  background: #f8fafc !important;
  border: 1px solid var(--apple-border) !important;
  color: var(--apple-text-soft) !important;
}

/* ── Tabs ── */
.tabs { display: flex; gap: 8px; flex-wrap: wrap; margin: 8px 0 14px; }
.tabs button {
  all: unset; cursor: pointer; padding: 8px 10px;
  border-radius: 12px; font-size: 13px;
  transition: background-color var(--dur) ease, border-color var(--dur) ease,
              color var(--dur) ease, box-shadow var(--dur) ease;
  background: var(--apple-surface) !important;
  color: var(--apple-text-soft) !important;
  border: 1px solid var(--apple-border) !important;
  box-shadow: 0 3px 10px rgba(15,23,42,.05);
}
.tabs button:hover {
  background: var(--apple-surface-2) !important;
  border-color: rgba(37,99,235,.28) !important;
  color: var(--apple-text) !important;
}
.tabs button:focus-visible { outline: none; box-shadow: var(--focus-ring); }

/* ── SVG chart wrapper ── */
.svgwrap {
  width: 100%; overflow: auto; border-radius: 14px;
  background: #fbfdff !important;
  border: 1px solid rgba(15,23,42,.10) !important;
}
.svgwrap svg { min-width: 720px; display: block; }
@media (max-width: 980px) { .svgwrap svg { min-width: 0; width: 100%; height: auto; } }

/* ── Callout ── */
.callout {
  display: flex; gap: 12px; padding: 12px;
  border: 1px solid var(--line); border-radius: 14px;
  background: rgba(255,255,255,.74);
}
.callout .dot {
  width: 10px; height: 10px; border-radius: 50%;
  margin-top: 6px; background: var(--brand);
}

/* ── Validation ── */
.validation-shell { width: 100%; }
.validation-head {
  display: flex; align-items: center; justify-content: space-between;
  gap: 8px; flex-wrap: wrap;
}
.validation-badges { display: flex; gap: 6px; flex-wrap: wrap; }
.validation-list {
  margin: 8px 0 0; padding: 0; list-style: none; display: grid; gap: 6px;
}
.validation-item {
  border: 1px solid var(--line); border-radius: 12px;
  padding: 8px 10px; background: rgba(255,255,255,.08);
  display: grid; grid-template-columns: auto 1fr auto;
  gap: 8px; align-items: center;
}
.validation-item--error { border-color: rgba(251,113,133,.28); background: rgba(251,113,133,.10); }
.validation-item--warning { border-color: rgba(251,191,36,.28); background: rgba(251,191,36,.10); }
.validation-item-type {
  font-size: 11px; text-transform: uppercase;
  letter-spacing: .07em; color: var(--muted); font-weight: 700;
}
.validation-item-msg { font-size: 13px; }
.validation-focus-btn { padding: 5px 9px; border-radius: 10px; font-size: 12px; }
.validation-info {
  margin-top: 8px; border: 1px solid var(--line);
  border-radius: 12px; background: rgba(255,255,255,.06); padding: 8px 10px;
}
.validation-info summary { cursor: pointer; color: var(--muted); font-size: 12px; font-weight: 600; }
.validation-info ul { margin: 8px 0 0 16px; font-size: 12px; display: grid; gap: 4px; }

/* ── Tip cards (hidden in current theme, structural retained) ── */
.tipGrid { display: none !important; }
.tipCard {
  grid-column: span 4; border: 1px dashed rgba(59,130,246,.30);
  background: rgba(59,130,246,.06); border-radius: 14px;
  padding: 12px; display: flex; gap: 10px; align-items: flex-start;
}
.tipCard .ticon {
  width: 28px; height: 28px; border-radius: 10px;
  background: rgba(59,130,246,.15);
  display: flex; align-items: center; justify-content: center; font-weight: 800;
}
.tipCard .ttitle { font-weight: 700; font-size: 13px; }
.tipCard .ttext { color: var(--muted); font-size: 12px; margin-top: 2px; line-height: 1.35; }
@media (max-width: 980px) { .tipCard { grid-column: span 12; } }

/* ── Help page visuals ── */
.helpHero {
  display: flex; gap: 12px; align-items: flex-start; padding: 14px;
  border: 1px solid rgba(167,139,250,.25);
  background: linear-gradient(135deg, rgba(110,231,255,.10), rgba(167,139,250,.10));
  border-radius: 16px;
}
.helpHero .hicon {
  width: 44px; height: 44px; border-radius: 16px;
  background: rgba(255,255,255,.08);
  display: flex; align-items: center; justify-content: center; font-size: 22px;
}
.helpHero h4 { margin: 0 0 4px; font-size: 15px; }
.helpHero p { margin: 0; color: var(--muted); font-size: 13px; line-height: 1.45; }

details.helpAcc {
  border: 1px solid var(--line); border-radius: 14px;
  background: rgba(255,255,255,.03); padding: 10px 12px;
}
details.helpAcc summary {
  cursor: pointer; list-style: none;
  display: flex; align-items: center; justify-content: space-between; gap: 10px;
  border-radius: 12px; transition: background-color var(--dur) ease;
}
details.helpAcc summary:hover { background: rgba(15,23,42,.03); }
details.helpAcc summary:focus-visible { outline: none; box-shadow: var(--focus-ring); border-radius: 12px; }
details.helpAcc summary::-webkit-details-marker { display: none; }
details.helpAcc summary .q { font-weight: 700; font-size: 13px; }
details.helpAcc summary .chev { color: var(--muted); }
details.helpAcc[open] { border-color: rgba(110,231,255,.28); background: rgba(110,231,255,.05); }
details.helpAcc .a { color: var(--muted); font-size: 12.5px; line-height: 1.45; margin-top: 8px; }

.helpSteps { display: grid; grid-template-columns: repeat(12,1fr); gap: 12px; }
.helpSteps .step {
  grid-column: span 4; border: 1px solid var(--line);
  border-radius: 14px; background: rgba(255,255,255,.03); padding: 12px;
}
.helpSteps .step .num {
  width: 26px; height: 26px; border-radius: 10px;
  background: rgba(251,191,36,.16); color: var(--warn);
  display: flex; align-items: center; justify-content: center;
  font-weight: 800; margin-bottom: 8px;
}
.helpSteps .step h5 { margin: 0 0 6px; font-size: 13px; }
.helpSteps .step p { margin: 0; color: var(--muted); font-size: 12px; line-height: 1.4; }
@media (max-width: 980px) { .helpSteps .step { grid-column: span 12; } }

/* ── Footer & separator ── */
.footer { margin-top: 14px; color: var(--muted); font-size: 12px; }
.hr { height: 1px; background: var(--line); margin: 12px 0; }

/* ── Toast ── */
#toastWrap { position: fixed; right: 16px; bottom: 16px; display: grid; gap: 10px; z-index: 9999; }
.toast {
  max-width: 360px; padding: 10px 12px; border-radius: 14px;
  border: 1px solid var(--line); background: rgba(255,255,255,.96);
  box-shadow: var(--shadow); display: flex; gap: 10px; align-items: flex-start;
}
.toast .ticon {
  width: 22px; height: 22px; border-radius: 8px;
  display: flex; align-items: center; justify-content: center; font-weight: 800;
}
.toast.good .ticon { background: rgba(52,211,153,.16); color: var(--good); }
.toast.warn .ticon { background: rgba(251,191,36,.16); color: var(--warn); }
.toast.bad .ticon  { background: rgba(251,113,133,.16); color: var(--bad); }
.toast .tmain { font-size: 13px; }
.toast .tsub { font-size: 12px; color: var(--muted); margin-top: 2px; }

/* ── Progress bar ── */
.progress {
  width: 220px; height: 8px; border-radius: 999px;
  border: 1px solid var(--line); background: rgba(255,255,255,.06); overflow: hidden;
}
.progress > div {
  height: 100%; width: 0%;
  background: linear-gradient(90deg, rgba(110,231,255,.95), rgba(167,139,250,.95));
}

/* ── Risk / stress cards ── */
.risk-shell {
  border: 1px solid rgba(15,23,42,.08); border-radius: 14px;
  padding: 12px; background: rgba(255,255,255,.5);
}
.risk-head {
  display: flex; justify-content: space-between;
  gap: 10px; align-items: flex-start; margin-bottom: 10px;
}
.risk-list { display: grid; gap: 8px; }
.risk-row {
  display: flex; justify-content: space-between; gap: 12px;
  align-items: flex-start;
  border: 1px solid rgba(15,23,42,.08); border-radius: 10px;
  padding: 9px 10px; background: rgba(255,255,255,.74);
}
.risk-row-kpis { display: flex; flex-wrap: wrap; gap: 8px; justify-content: flex-end; }
.risk-bucket-row {
  display: grid; grid-template-columns: repeat(3,minmax(0,1fr));
  gap: 8px; margin-bottom: 10px;
}
.risk-pill {
  border: 1px solid rgba(15,23,42,.08); border-radius: 10px;
  padding: 8px 10px; background: rgba(248,250,252,.95);
}
.risk-watchout {
  border: 1px solid rgba(15,23,42,.08); border-radius: 10px;
  padding: 9px 10px; background: rgba(255,255,255,.72); margin-bottom: 8px;
}
.risk-watchout-good { background: var(--apple-good-bg) !important; border-color: rgba(21,128,61,.26) !important; }
.risk-watchout-warn { background: var(--apple-warn-bg) !important; border-color: rgba(180,83,9,.26) !important; }
.risk-watchout-bad  { background: var(--apple-bad-bg) !important;  border-color: rgba(190,18,60,.26) !important; }

/* ── Repeat cards ── */
.repeatWrap { display: grid; gap: 10px; }
.repeatCard {
  border: 1px solid var(--line); background: rgba(255,255,255,.03);
  border-radius: 14px; padding: 12px;
}
.repeatHead {
  display: flex; justify-content: space-between;
  align-items: center; gap: 8px; margin-bottom: 10px;
}
.repeatTitle { font-weight: 700; font-size: 13px; }
.repeatActions { display: flex; gap: 6px; align-items: center; }
.repeatMeta { display: flex; flex-wrap: wrap; gap: 6px; margin: -4px 0 10px; }
.repeatMeta .badge { font-size: 11px; padding: 3px 8px; }
.repeatEmpty {
  border: 1px dashed var(--line); border-radius: 14px;
  padding: 12px; background: rgba(255,255,255,.02);
}
.repeatEmptyTitle { font-size: 13px; font-weight: 700; margin-bottom: 4px; }
.miniBtn {
  all: unset; cursor: pointer; color: var(--bad); font-size: 12px;
  padding: 6px 8px; border: 1px solid rgba(251,113,133,.35);
  border-radius: 10px; background: rgba(251,113,133,.08);
  transition: background-color var(--dur) ease, border-color var(--dur) ease;
}
.miniBtn.clone {
  color: var(--brand); border-color: rgba(110,231,255,.35);
  background: rgba(110,231,255,.08);
}
.hint { font-size: 11px; color: var(--muted); }

/* ── Global view-header pattern (eyebrow / h3 / subtitle) ── */
.view-eyebrow, .overview-eyebrow {
  font-size: 12px !important; font-weight: 700 !important;
  letter-spacing: .10em !important; color: #475569 !important;
  margin-bottom: 6px !important; text-transform: uppercase !important;
}
.view-subtitle, .overview-subtitle {
  font-size: 15px !important; color: #64748b !important;
  margin: 0 0 20px 0 !important; font-weight: 400 !important;
  line-height: 1.5 !important;
}
/* h3 inside every view shell */
.overview-shell > h3, .inputs-shell > h3, .projection-shell > h3, .bridge-shell > h3,
.strategy-intro-card > h3, .household-view-shell > h3,
.stress-shell > h3, .monte-shell > h3,
.scenarios-shell > h3, .help-shell > h3 {
  font-size: 32px !important; font-weight: 800 !important;
  color: #0f172a !important; letter-spacing: -.03em !important;
  margin: 0 0 4px !important;
}

/* All outer shell cards → transparent, no box */
.overview-shell.card, .inputs-shell.card, .projection-shell.card,
.bridge-shell.card, .strategy-intro-card.card,
.household-view-shell.card, .stress-shell.card,
.monte-shell.card, .scenarios-shell.card, .help-shell.card {
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
  padding: 0 !important;
}

/* Hide redundant muted paragraphs below subtitle */
.view-subtitle + .tipGrid + .muted,
.view-subtitle + .muted,
.strategy-intro-card > .view-subtitle + .muted {
  display: none !important;
}

/* Confidence badges (Inputs) */
.inputs-confidence-row {
  display: flex !important; flex-wrap: wrap !important;
  gap: 10px !important; margin-bottom: 16px !important;
}
.inputs-confidence-row .badge {
  font-size: 12px !important; font-weight: 500 !important;
  padding: 5px 14px !important; border-radius: 999px !important;
  background: rgba(248,250,252,.9) !important;
  border: 1px solid rgba(15,23,42,.08) !important;
  color: #475569 !important; box-shadow: none !important;
}

/* Status rows (Stress, Monte) */
.stress-status-row, .monte-status-row {
  display: flex; flex-wrap: wrap; gap: 10px; align-items: center;
  margin-top: 4px !important; margin-bottom: 16px !important;
}
.stress-status-row .badge, .monte-status-row .badge {
  font-size: 12px !important; font-weight: 500 !important;
  border-radius: 999px !important;
}

/* Inner cards within views */
#view-strategy .card, #view-bridge .card,
#view-household .card, #view-scenarios .card {
  background: #ffffff !important;
  border: 1px solid rgba(15,23,42,.07) !important;
  box-shadow: 0 1px 3px rgba(15,23,42,.04), 0 4px 12px rgba(15,23,42,.03) !important;
  border-radius: 16px !important;
  color: #334155 !important;
}
/* …but not the outer shell cards themselves */
#view-strategy .strategy-intro-card.card,
#view-bridge .bridge-shell.card,
#view-household .household-view-shell.card,
#view-scenarios .scenarios-shell.card {
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
}

/* ── Chart components ── */
.overview-chart-header {
  display: flex !important; justify-content: space-between !important;
  align-items: flex-start !important; margin-bottom: 4px !important;
}
.overview-chart-header h4 {
  font-size: 17px !important; font-weight: 700 !important;
  color: #0f172a !important; margin: 0 0 2px !important;
  padding: 0 !important; border: none !important;
  font-family: system-ui,-apple-system,sans-serif !important;
}
.overview-chart-subtitle {
  font-size: 13.5px !important; color: #94a3b8 !important;
  margin: 0 !important; font-weight: 400 !important;
  font-family: system-ui,-apple-system,sans-serif !important;
}
.overview-visual-panel .svgwrap { overflow: hidden !important; }
.overview-visual-panel svg {
  width: 100% !important; height: auto !important; display: block !important;
}
.chart-tooltip {
  position: absolute !important; pointer-events: none !important;
  background: rgba(255,255,255,.96) !important;
  backdrop-filter: blur(12px) !important;
  -webkit-backdrop-filter: blur(12px) !important;
  border: 1px solid rgba(15,23,42,.06) !important;
  border-radius: 12px !important;
  padding: 10px 16px !important;
  font-size: 13px !important; color: #334155 !important;
  box-shadow: 0 8px 24px rgba(15,23,42,.08), 0 2px 6px rgba(15,23,42,.04) !important;
  opacity: 0 !important;
  transition: opacity var(--dur-fast) ease !important;
  white-space: nowrap !important; z-index: 10 !important;
  transform: translateX(-50%) !important;
  line-height: 1.6 !important;
  font-family: system-ui,-apple-system,sans-serif !important;
}
.chart-tooltip strong {
  font-weight: 700 !important; color: #0f172a !important;
  font-size: 14px !important;
}

/* ── Bridge KPI grid ── */
#bridgeKpis { display: block; margin-top: 12px; }
#bridgeKpis > .bridge-kpi-grid { width: 100%; }
.bridge-kpi-grid {
  display: grid; grid-template-columns: repeat(12,minmax(0,1fr));
  gap: 10px; margin-top: 12px;
}
.bridge-kpi { grid-column: span 4; border-radius: 14px; padding: 11px 12px; }
.bridge-kpi .label { margin-bottom: 6px; }

/* ── Strategy utility classes (consumed by JS renderers) ── */
.strategy-full-span { grid-column: span 12; }
.strategy-col-4 { grid-column: span 4; }
.strategy-overflow { overflow: auto; }
.strategy-chip-row { margin-top: 8px; gap: 8px; flex-wrap: wrap; }
.strategy-top-gap { margin-top: 10px; }
.strategy-top-gap-md { margin-top: 12px; }
.strategy-top-gap-sm { margin-top: 8px; }
.strategy-top-gap-xs { margin-top: 6px; }
.strategy-top-gap-xxs { margin-top: 3px; }
.strategy-gap-xs { margin-top: 6px; }
.strategy-bottom-gap-xs { margin-bottom: 6px; }
.strategy-bottom-gap-sm { margin-bottom: 8px; }
.strategy-tight-bottom { margin: 0 0 12px; }
.strategy-tight-top { margin-top: 6px; }
.strategy-block-gap { margin-bottom: 16px; }
.strategy-strong { font-weight: 700; }
.strategy-strong-lite { font-weight: 600; }
.strategy-selected-name { color: var(--brand); }
.strategy-top-pick { color: var(--brand); }
.strategy-row-top td { background: rgba(37,99,235,.08); }
.strategy-mini-charts { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.strategy-axis-row { display: flex; justify-content: space-between; margin-top: 2px; }
.strategy-timeline-content { flex: 1; }


/* ── View text-color baseline ── */
:is(#view-overview, #view-inputs, #view-projection, #view-strategy,
    #view-bridge, #view-household, #view-scenarios, #view-help,
    #view-stress, #view-monte) {
  color: #111827;
}

/* ── Outcome cards (Stress + Monte shared) ── */
:is(.stress-outcome-card, .monte-outcome-card) {
  border: 1px solid rgba(148,163,184,.24); border-radius: 12px;
  background: rgba(255,255,255,.86); padding: 10px; display: grid; gap: 4px;
}
:is(.stress-outcome-card, .monte-outcome-card).good { border-color: rgba(22,163,74,.28); background: rgba(240,253,244,.92); }
:is(.stress-outcome-card, .monte-outcome-card).warn { border-color: rgba(217,119,6,.30); background: rgba(255,247,237,.92); }
:is(.stress-outcome-card, .monte-outcome-card).bad  { border-color: rgba(220,38,38,.30); background: rgba(254,242,242,.92); }
:is(.stress-outcome-card, .monte-outcome-card).info { border-color: rgba(37,99,235,.24); background: rgba(239,246,255,.92); }

:is(.stress-outcome-label, .monte-outcome-label) {
  font-size: 11px; color: #64748b; text-transform: uppercase;
  letter-spacing: .04em; font-weight: 700;
}
:is(.stress-outcome-value, .monte-outcome-value) {
  color: #0f172a; font-size: 14px; font-weight: 600; line-height: 1.35;
}

/* ── Outcome grids (Stress + Monte shared) ── */
:is(.stress-outcome-grid, .monte-outcome-grid) {
  display: grid; gap: 10px; margin-bottom: 10px;
}

/* ── Context notes (Stress + Monte shared) ── */
:is(.stress-context-note, .monte-context-note) {
  border: 1px solid rgba(37,99,235,.15); border-radius: 12px;
  background: rgba(239,246,255,.65); color: #334155;
  font-size: 12px; line-height: 1.45; padding: 8px 10px; margin-bottom: 10px;
}

/* ── Advanced details (Stress + Monte shared) ── */
:is(.stress-advanced-details, .monte-advanced-details) {
  border: 1px solid rgba(148,163,184,.26); border-radius: 12px;
  background: rgba(255,255,255,.72); padding: 8px 10px;
}
:is(.stress-advanced-details, .monte-advanced-details) summary {
  cursor: pointer; color: #334155; font-weight: 600; font-size: 12px; list-style: none;
  border-radius: 10px; padding: 4px 6px; margin: -4px -6px;
  transition: background-color var(--dur) ease;
}
:is(.stress-advanced-details, .monte-advanced-details) summary:hover {
  background: rgba(15,23,42,.03);
}
:is(.stress-advanced-details, .monte-advanced-details) summary:focus-visible {
  outline: none; box-shadow: var(--focus-ring);
}
:is(.stress-advanced-details, .monte-advanced-details) summary::-webkit-details-marker { display: none; }

/* ── Analysis panels (Stress + Monte shared) ── */
:is(.stress-panel, .monte-panel) {
  grid-column: span 6; border-radius: 20px; padding: 14px;
}
:is(.stress-panel--wide, .monte-panel--wide) { grid-column: span 12; }
:is(.stress-panel, .monte-panel) h4 { margin: 0 0 10px; font-size: 16px; color: #111827; }

/* ── Analysis grids (Stress + Monte shared) ── */
:is(.stress-grid, .monte-grid) {
  display: grid; grid-template-columns: repeat(12,minmax(0,1fr)); gap: 12px;
}

/* ── Shared tipCard overrides (Stress + Monte) ── */
:is(#view-stress, #view-monte) .tipCard {
  border-color: rgba(37,99,235,.18); background: rgba(59,130,246,.05);
}
:is(#view-stress, #view-monte) .tipCard .ticon { background: rgba(59,130,246,.12); }
:is(#view-stress, #view-monte) .tipCard .ttitle { color: #111827; }

/* ── Shared h3/h4 baseline (Stress + Monte) ── */
:is(#view-stress, #view-monte) :is(h3, h4) { color: #111827; letter-spacing: -.02em; }

/* ── Preset / mode buttons (Stress) ── */
.stress-preset-btn, .stress-chart-mode-btn {
  background: var(--apple-surface) !important;
  color: var(--apple-text-soft) !important;
  border: 1px solid var(--apple-border) !important;
  box-shadow: 0 3px 10px rgba(15,23,42,.05);
  transition: background-color var(--dur) ease, border-color var(--dur) ease,
              color var(--dur) ease, box-shadow var(--dur) ease;
}
.stress-preset-btn:hover, .stress-chart-mode-btn:hover {
  background: var(--apple-surface-2) !important;
  border-color: rgba(37,99,235,.28) !important;
  color: var(--apple-text) !important;
}
.stress-preset-btn:focus-visible, .stress-chart-mode-btn:focus-visible {
  outline: none; box-shadow: var(--focus-ring);
}


/* ═══════════════════════════════════════════════════════════════
   4 · PAGES  —  Per-view layout & unique overrides
   ═══════════════════════════════════════════════════════════════ */

/* ──────────────────────────────────────────────
   4a · Overview
   ────────────────────────────────────────────── */
/* View color, shell, eyebrow, subtitle, h3 now standardised in Section 3 */

/* Summary cards */
#view-overview .overview-summary-grid {
  display: grid; grid-template-columns: repeat(5,minmax(0,1fr));
  gap: 16px !important; margin-top: 18px; margin-bottom: 0 !important;
}
#view-overview .overview-summary-card {
  border-radius: 16px !important;
  padding: 20px !important;
  min-height: 116px;
  transition: box-shadow var(--dur) ease, transform var(--dur) ease !important;
}
#view-overview .overview-summary-card:hover {
  box-shadow: 0 2px 6px rgba(15,23,42,.08), 0 10px 24px rgba(15,23,42,.06) !important;
  transform: translateY(-1px) !important;
}
#view-overview .overview-summary-card .overview-summary-value {
  font-size: clamp(26px, 1.6vw, 32px) !important; line-height: 1.2 !important;
  color: #0f172a !important; font-weight: 700 !important;
}
#view-overview .overview-summary-card .overview-summary-label {
  font-size: 12px !important; font-weight: 600 !important;
  color: #64748b !important; letter-spacing: .03em !important;
  text-transform: uppercase !important; margin-bottom: 8px !important;
}
#view-overview .overview-summary-value { margin-top: 6px; line-height: 1.05; }
#view-overview .overview-sparkline { width: 100%; height: 34px; margin-top: 8px; display: block; overflow: visible; }
#view-overview .overview-sparkline path {
  fill: none; stroke: #3b82f6; stroke-width: 2;
  stroke-linecap: round; stroke-linejoin: round; opacity: .85;
}
#view-overview .overview-summary-detail { margin-top: 10px; font-size: 12px; line-height: 1.45; }

.overview-summary-card--core    { border-top: 3px solid rgba(37,99,235,.45) !important; }
.overview-summary-card--income  { border-top: 3px solid rgba(8,145,178,.45) !important; }
.overview-summary-card--future  { border-top: 3px solid rgba(99,102,241,.40) !important; }
.overview-summary-card--household { border-top: 3px solid rgba(14,116,144,.45) !important; }

/* Status badges */
#view-overview .overview-status-row {
  background: transparent !important; border: none !important;
  padding: 0 !important;
  margin-top: 20px !important; margin-bottom: 8px !important;
  display: flex; flex-wrap: wrap; gap: 10px !important; align-items: center;
}
#view-overview .overview-status-row .badge {
  font-size: 12px !important; font-weight: 500 !important;
  padding: 5px 14px !important; border-radius: 999px !important;
  background: rgba(248,250,252,.9) !important;
  border: 1px solid rgba(15,23,42,.08) !important;
  color: #475569 !important; box-shadow: none !important;
}
#view-overview .overview-status-row .badge.good {
  background: rgba(240,253,244,.9) !important;
  border-color: rgba(34,197,94,.2) !important; color: #166534 !important;
}
#view-overview .overview-status-row .badge.warn {
  background: rgba(255,251,235,.9) !important;
  border-color: rgba(245,158,11,.2) !important; color: #92400e !important;
}
#view-overview .overview-status-row .badge.bad {
  background: rgba(254,242,242,.9) !important;
  border-color: rgba(239,68,68,.2) !important; color: #991b1b !important;
}

/* Panels */
#view-overview .overview-grid {
  margin-top: 24px !important; display: grid;
  grid-template-columns: repeat(12,minmax(0,1fr)); gap: 16px !important;
}
#view-overview .overview-panel {
  grid-column: span 6;
  background: #ffffff !important;
  border: 1px solid rgba(15,23,42,.07) !important;
  box-shadow: 0 1px 3px rgba(15,23,42,.04), 0 4px 12px rgba(15,23,42,.03) !important;
  border-radius: 16px !important;
  padding: 20px !important;
  color: #334155 !important;
}
#view-overview .overview-panel--wide { grid-column: span 12; }
#view-overview .overview-panel h4 {
  font-size: 16px !important; font-weight: 700 !important;
  color: #0f172a !important; margin: 0 0 14px !important;
  padding-bottom: 12px !important;
  border-bottom: 1px solid rgba(15,23,42,.06) !important;
}

/* Inner items */
#view-overview :is(.overview-breakdown-item, .overview-watchout,
  .overview-bridge-summary, .overview-change-item) {
  background: #fafbfc !important;
  border: 1px solid rgba(15,23,42,.05) !important;
  box-shadow: none !important;
  border-radius: 10px !important;
  color: #475569 !important;
}
#view-overview .overview-breakdown-grid {
  display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 10px;
}
#view-overview .overview-breakdown-item {
  padding: 10px 12px;
  display: flex; justify-content: space-between; gap: 8px; align-items: center;
}
#view-overview .overview-breakdown-item.is-emphasis {
  border-color: rgba(37,99,235,.2); background: rgba(239,246,255,.76);
}
#view-overview .overview-breakdown-label { color: #516176; font-size: 12px; line-height: 1.4; }
#view-overview .overview-breakdown-item strong {
  color: #111827; font-size: 15px; line-height: 1.2; white-space: nowrap;
}

/* Watchouts */
#view-overview .overview-watchouts { display: grid; gap: 10px; }
#view-overview .overview-watchout {
  padding: 10px 12px; display: grid; gap: 8px;
}
#view-overview .overview-watchout-title { font-weight: 700; color: #1f2937; }
#view-overview .overview-watchout--info,
#view-overview .overview-watchout--warn,
#view-overview .overview-watchout--bad { border-left: 4px solid transparent !important; }
#view-overview .overview-watchout--info {
  background: #eff6ff !important; border-color: rgba(37,99,235,.24) !important;
  border-left-color: rgba(37,99,235,.62) !important;
}
#view-overview .overview-watchout--warn {
  background: var(--apple-warn-bg) !important; border-color: rgba(180,83,9,.24) !important;
  border-left-color: rgba(180,83,9,.58) !important;
}
#view-overview .overview-watchout--bad {
  background: var(--apple-bad-bg) !important; border-color: rgba(190,18,60,.24) !important;
  border-left-color: rgba(190,18,60,.58) !important;
}

/* Bridge summary */
#view-overview .overview-bridge-summary {
  background: #ffffff !important;
  border-color: var(--apple-border-strong) !important;
  border-left: 4px solid rgba(148,163,184,.55) !important;
  border-radius: 10px; padding: 12px; display: grid; gap: 8px;
}
#view-overview .overview-bridge-summary--good {
  background: var(--apple-good-bg) !important;
  border-color: rgba(21,128,61,.26) !important;
  border-left-color: rgba(21,128,61,.64) !important;
}
#view-overview .overview-bridge-summary--warn {
  background: var(--apple-warn-bg) !important;
  border-color: rgba(180,83,9,.26) !important;
  border-left-color: rgba(180,83,9,.64) !important;
}
#view-overview .overview-bridge-summary--bad {
  background: var(--apple-bad-bg) !important;
  border-color: rgba(190,18,60,.26) !important;
  border-left-color: rgba(190,18,60,.64) !important;
}
#view-overview .overview-bridge-row {
  display: flex; align-items: center; justify-content: space-between;
  gap: 10px; border: 1px solid rgba(148,163,184,.2);
  border-radius: 10px; padding: 8px 9px;
}
#view-overview .overview-bridge-summary .overview-bridge-row {
  background: #f8fafc !important; border: 1px solid rgba(15,23,42,.08) !important;
}
#view-overview .overview-bridge-summary--good .overview-bridge-row,
#view-overview .overview-bridge-summary--warn .overview-bridge-row,
#view-overview .overview-bridge-summary--bad .overview-bridge-row {
  background: rgba(255,255,255,.78) !important;
  border-color: rgba(15,23,42,.08) !important;
}
#view-overview .overview-bridge-row span { color: var(--apple-text-muted) !important; font-size: 12px; line-height: 1.35; }
#view-overview .overview-bridge-row strong {
  color: var(--apple-text) !important; font-weight: 630 !important;
  font-size: 13px; line-height: 1.2; text-align: right; white-space: nowrap;
}

/* Changes / compare */
#view-overview .overview-changes-summary { margin-bottom: 8px; font-size: 12px; }
#view-overview .overview-compare-controls {
  display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 10px;
}
#view-overview .overview-compare-controls select {
  min-width: 240px; max-width: 100%;
  background: rgba(255,255,255,.9); color: #1f2937;
  border: 1px solid rgba(148,163,184,.3);
}
#view-overview .overview-compare-controls select:disabled { opacity: .6; }
#view-overview .overview-changes-grid { display: grid; gap: 8px; }
#view-overview .overview-change-item {
  padding: 10px 12px;
  display: flex; justify-content: space-between; gap: 10px; align-items: center;
}
#view-overview .overview-change-item span { color: #516176; font-size: 12px; }
#view-overview .overview-change-item strong { color: #111827; font-size: 14px; white-space: nowrap; }

/* Next steps */
#view-overview .overview-next-steps { display: grid; gap: 8px; }
#view-overview .overview-next-step {
  border: 1px solid rgba(37,99,235,.12) !important; border-radius: 10px !important;
  background: rgba(239,246,255,.70) !important; padding: 12px; text-align: left;
  display: grid; gap: 4px; cursor: pointer;
  box-shadow: none !important; color: #475569 !important;
  transition: background-color var(--dur) ease, border-color var(--dur) ease;
}
#view-overview .overview-next-step-title { color: #12335f; font-weight: 700; }
#view-overview .overview-next-step:hover {
  background: rgba(219,234,254,.92) !important; border-color: rgba(37,99,235,.26) !important;
}
#view-overview .overview-visual-panel .svgwrap {
  border-radius: 14px; border: 1px solid rgba(15,23,42,.06);
  background: #fff; box-shadow: 0 1px 3px rgba(15,23,42,.04); padding: 0;
}


/* ──────────────────────────────────────────────
   4b · Inputs
   ────────────────────────────────────────────── */
/* View color, shell, muted, badge, tipCard now standardised in Section 3 */
#view-inputs .inputs-confidence-row { margin-top: 12px; }
#view-inputs #validationSummary { border-color: rgba(245,158,11,.22); background: rgba(255,251,235,.84); }

/* Tabs */
#view-inputs .tabs {
  margin: 10px 0 14px; padding: 10px; border-radius: 16px;
  border: 1px solid rgba(15,23,42,.08); background: rgba(255,255,255,.68);
}
#view-inputs .tabs button.tab-global { border-style: dashed; }

/* Sub-tabs */
#view-inputs .subtabs {
  display: flex; flex-wrap: wrap; gap: 6px; margin: 0 0 18px; padding: 8px;
  background: rgba(255,255,255,.50); border: 1px solid rgba(15,23,42,.06); border-radius: 12px;
}
#view-inputs .subtabs button {
  background: rgba(255,255,255,.80); border: 1px solid rgba(15,23,42,.10);
  border-radius: 9px; color: #475569; font-size: 12px; font-weight: 500;
  padding: 6px 12px; cursor: pointer;
}
#view-inputs .subtabs button.active {
  background: rgba(59,130,246,.10); border-color: rgba(59,130,246,.30);
  color: #1e3a8a; font-weight: 600;
}

/* Person sections */
#view-inputs .person-section { margin-bottom: 20px; }
#view-inputs .person-section-title {
  font-size: 15px; font-weight: 700; color: #1e293b;
  margin: 0 0 12px; display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap;
}
#view-inputs .person-section-subtitle { font-size: 12px; font-weight: 400; color: #64748b; }
#view-inputs .person-section-divider { border: none; border-top: 1.5px solid rgba(15,23,42,.07); margin: 16px 0 22px; }
#view-inputs .inputs-tab-intro {
  margin: 2px 0 10px; padding: 10px 12px;
  border: 1px solid rgba(15,23,42,.08); border-radius: 14px;
  background: rgba(255,255,255,.74);
  display: flex; flex-direction: column; gap: 2px;
}
#view-inputs .person-badge-you {
  border-color: rgba(37,99,235,.24); background: rgba(239,246,255,.9);
  color: #1d4ed8; font-weight: 600;
}
#view-inputs .person-badge-partner {
  border-color: rgba(124,58,237,.24); background: rgba(245,243,255,.9);
  color: #6d28d9; font-weight: 600;
}

#view-inputs .callout { border-color: rgba(15,23,42,.10); }
#view-inputs .inputs-repeater-summary { margin: -2px 0 10px; font-weight: 600; color: #475467; }

/* Household section */
#view-inputs .household-shell { grid-column: 1 / -1; display: grid; gap: 10px; }
#view-inputs .household-section {
  border: 1px solid rgba(15,23,42,.10); background: rgba(255,255,255,.76);
  border-radius: 16px; padding: 12px;
  box-shadow: inset 0 1px 0 rgba(255,255,255,.8);
}
#view-inputs .household-section-title {
  font-size: 12px; font-weight: 700; letter-spacing: .06em;
  text-transform: uppercase; color: #4b5563; margin-bottom: 8px;
}
#view-inputs .household-grid { gap: 10px; }
#view-inputs .household-grid .field { grid-column: span 6; }
#view-inputs .household-grid .field .hint { margin-top: 1px; }
#view-inputs .inputs-repeater-summary .badge {
  margin-right: 6px; border-color: rgba(15,23,42,.12);
  background: rgba(255,255,255,.8); color: #334155; font-weight: 600;
}

/* Editor toggle */
#view-inputs .editor-person-toggle {
  display: inline-flex; align-items: center; gap: 6px; padding: 4px;
  border-radius: 12px; border: 1px solid rgba(15,23,42,.10);
  background: rgba(255,255,255,.75);
}
#view-inputs .editor-person-toggle .btn {
  padding: 6px 10px; font-size: 12px; border-radius: 10px;
  background: rgba(255,255,255,.9); color: #475467;
  border-color: rgba(15,23,42,.14);
}
#view-inputs .editor-person-toggle .btn.active,
#view-inputs .editor-person-toggle .btn[aria-pressed="true"] {
  background: rgba(37,99,235,.12); border-color: rgba(37,99,235,.26); color: #1d4ed8;
}

/* Validation */
#view-inputs .validation-focus-btn {
  background: rgba(59,130,246,.12); border-color: rgba(59,130,246,.25); color: #1e3a8a;
}
#view-inputs .miniBtn { color: #9f1239; border-color: rgba(225,29,72,.32); background: rgba(255,241,242,.9); }
#view-inputs .miniBtn.clone { color: #1d4ed8; border-color: rgba(59,130,246,.28); background: rgba(239,246,255,.9); }


/* ──────────────────────────────────────────────
   4c · Projection
   ────────────────────────────────────────────── */
/* View color, shell, muted now standardised in Section 3 */

/* Summary cards */
#view-projection .projection-summary-grid {
  display: grid; grid-template-columns: repeat(4,minmax(0,1fr));
  gap: 12px; margin-top: 14px;
}
#view-projection .projection-summary-card {
  border-radius: 20px; padding: 16px;
}
#view-projection .projection-summary-age {
  margin-top: 6px; font-size: 28px; line-height: 1.05;
}
#view-projection .projection-summary-kpis {
  display: grid; grid-template-columns: repeat(3,minmax(0,1fr));
  gap: 10px; margin-top: 12px;
}
#view-projection .projection-summary-kpi-label { display: block; margin-bottom: 4px; }
#view-projection .projection-summary-kpis strong { color: #111827; font-size: 15px; line-height: 1.2; }
#view-projection .projection-summary-highlight { margin-top: 12px; line-height: 1.45; min-height: 20px; }

/* Toolbar */
#view-projection .projection-toolbar {
  margin-top: 14px; display: flex; justify-content: space-between;
  gap: 12px; align-items: flex-start; flex-wrap: wrap;
}
#view-projection .projection-controls-cluster {
  display: flex; gap: 10px; align-items: flex-start;
  flex-wrap: wrap; justify-content: flex-end;
}
#view-projection .projection-help-text { color: #516176; max-width: 70ch; line-height: 1.5; }
#view-projection .projection-row-count { margin-top: 8px; font-size: 12px; }

/* Legend / event chips */
#view-projection .projection-legend-row,
#view-projection .projection-event-chip-row {
  display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px;
}
#view-projection .projection-event-chip-row { margin-bottom: 6px; }
#view-projection .projection-legend-chip,
#view-projection .projection-event-chip {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 4px 10px; border-radius: 999px;
  border: 1px solid rgba(15,23,42,.08);
  background: rgba(255,255,255,.9); font-size: 12px; color: #475467;
}
.projection-event-chip--milestone, .projection-legend-chip--milestone,
.projection-row--milestone td {
  background: #eff6ff !important; border-color: rgba(37,99,235,.22) !important;
  color: #1e3a8a !important;
}
.projection-event-chip--cash, .projection-legend-chip--cash,
.projection-row--cash td {
  background: #ecfeff !important; border-color: rgba(8,145,178,.24) !important;
  color: #155e75 !important;
}
.projection-event-chip--attention, .projection-legend-chip--attention,
.projection-row--attention td {
  background: var(--apple-warn-bg) !important; border-color: rgba(180,83,9,.24) !important;
  color: #9a3412 !important;
}
#view-projection .projection-legend-chip--income,
#view-projection .projection-event-chip--income {
  background: rgba(22,163,74,.08); border-color: rgba(22,163,74,.16); color: #255c3d;
}

/* Mode toggle */
#view-projection .projection-mode-toggle {
  display: inline-flex; gap: 8px; padding: 4px; border-radius: 16px;
  background: rgba(255,255,255,.72); border: 1px solid rgba(15,23,42,.08);
}
#view-projection .projection-mode-toggle .btn { background: transparent; color: #516176; border-color: transparent; }
#view-projection .projection-mode-toggle .btn.active {
  background: rgba(37,99,235,.12); border-color: rgba(37,99,235,.18); color: #12335f;
}
#view-projection .projection-header-badges .badge {
  background: rgba(255,255,255,.84); border-color: rgba(15,23,42,.08); color: #475467;
}
#view-projection .projection-header-badges .badge .ico { background: rgba(148,163,184,.18); }

/* Table shell */
#view-projection .projection-table-shell {
  border-radius: 16px; overflow: auto; max-width: 100%;
}
#view-projection #tblProjection {
  width: max-content; min-width: 100%; font-size: 13px;
  border-collapse: separate; border-spacing: 0;
  table-layout: auto; color: #111827;
}
#view-projection #tblProjection .projection-group-head th {
  position: sticky; top: 0; z-index: 4;
  font-size: 10px; letter-spacing: .16em; text-transform: uppercase;
  background: #f2f6fb !important; color: #64748b !important;
  border-bottom: 1px solid rgba(15,23,42,.10) !important;
  padding: 10px;
}
#view-projection #tblProjection thead tr:nth-child(2) th {
  position: sticky; top: 40px; z-index: 3;
  background: #f7fafe !important; color: #334155 !important;
  font-weight: 650; font-size: 12px; padding: 9px 10px; white-space: nowrap;
}
#view-projection #tblProjection td {
  padding: 9px 10px; line-height: 1.35; color: #1f2937;
  border-bottom: 1px solid rgba(15,23,42,.07) !important;
  background: rgba(255,255,255,.86); white-space: nowrap;
}
#view-projection #tblProjection tbody tr:hover td { background: #f8fbff !important; }

/* Milestone column */
#view-projection .projection-col-milestones,
#view-projection .projection-milestone-cell {
  width: 52px; min-width: 52px; text-align: center;
  position: sticky; left: 0; z-index: 2; background: inherit;
}
#view-projection .projection-col-age, #view-projection .projection-age-cell { min-width: 72px; }
#view-projection .projection-col-phase, #view-projection .projection-phase-cell { min-width: 128px; }

#view-projection .projection-milestone-dot {
  display: inline-flex; width: 20px; height: 20px; border-radius: 999px;
  align-items: center; justify-content: center;
  font-size: 11px; font-weight: 700; border: 1px solid transparent; color: #0f172a;
}
#view-projection .projection-milestone-dot--milestone { background: #e0f2fe; border-color: #7dd3fc; color: #0c4a6e; }
#view-projection .projection-milestone-dot--income { background: #dcfce7; border-color: #86efac; color: #14532d; }
#view-projection .projection-milestone-dot--cash { background: #f3e8ff; border-color: #d8b4fe; color: #6b21a8; }
#view-projection .projection-milestone-dot--bad { background: #fee2e2; border-color: #fca5a5; color: #7f1d1d; }
#view-projection .projection-milestone-empty { color: #cbd5e1; font-weight: 600; }

/* Phase pill */
#view-projection .projection-phase-pill {
  display: inline-flex; align-items: center; padding: 2px 10px;
  border-radius: 999px; border: 1px solid rgba(37,99,235,.22);
  background: #eef5ff; color: #1d4ed8; font-size: 11px; line-height: 1.2;
}
#view-projection .projection-phase-pill--retired {
  border-color: rgba(239,68,68,.24); background: #fff1f2; color: #b91c1c;
}

/* Age + events columns */
#view-projection .projection-age-cell .projection-age-phase { display: none; }
#view-projection .projection-age-cell { min-width: 72px; }
#view-projection .projection-age-value {
  font-size: 15px; line-height: 1.1;
}
#view-projection .projection-age-phase {
  margin-top: 4px; color: #667085; font-size: 11px;
  text-transform: uppercase; letter-spacing: .08em;
}
#view-projection .projection-emphasis-cell { font-weight: 700; color: #111827; white-space: nowrap; }
#view-projection .projection-events-column {
  min-width: 300px; max-width: 420px; white-space: normal;
}
#view-projection .projection-note-list { display: grid; gap: 2px; }
#view-projection .projection-note-line {
  font-size: 12px; line-height: 1.45; color: #475569 !important;
}
#view-projection #tblProjection td.right,
#view-projection #tblProjection th.right { white-space: nowrap; }
#view-projection #tblProjection.projection-table--compact { min-width: 980px; }

/* Row highlights */
#view-projection .projection-row--milestone,
#view-projection .projection-row.is-retirement-start,
#view-projection .projection-row.is-state-pension-start,
#view-projection .projection-row.is-db-start { background: rgba(37,99,235,.045); }
#view-projection .projection-row--cash,
#view-projection .projection-row.has-lump-sum { background: rgba(217,119,6,.05); }
#view-projection .projection-row--attention,
#view-projection .projection-row.has-income-drop { background: rgba(220,38,38,.055); }

/* Detail rows */
#view-projection .projection-detail-toggle {
  margin-top: 10px; padding: 6px 9px; border-radius: 10px; font-size: 12px;
  background: rgba(255,255,255,.88); color: #34507a; border-color: rgba(37,99,235,.18);
}
#view-projection .projection-row-detail-shell td {
  padding: 0 10px 12px; background: rgba(255,255,255,.72);
}
#view-projection .projection-row-detail-card {
  border-radius: 16px; padding: 12px;
}
#view-projection .projection-row-detail-grid {
  display: grid; grid-template-columns: repeat(4,minmax(0,1fr)); gap: 10px;
}
#view-projection .projection-row-detail-item {
  border-radius: 12px; padding: 10px;
  display: flex; flex-direction: column; gap: 4px;
}
#view-projection .projection-row-detail-label { color: #667085; font-size: 11px; line-height: 1.35; }
#view-projection .projection-row-detail-item strong { color: #111827; font-size: 14px; line-height: 1.2; }
#view-projection .projection-note-list { display: grid; gap: 4px; margin-top: 8px; }
#view-projection .projection-note-line { color: #516176; line-height: 1.45; }
#view-projection .projection-col-tip {
  display: inline-flex; align-items: center; justify-content: center;
  margin-left: 4px; width: 15px; height: 15px; border-radius: 50%;
  border: 1px solid rgba(100,116,139,.35); background: rgba(241,245,249,.9);
  color: #6b7280; font-size: 9px; cursor: help; vertical-align: middle;
  line-height: 1; padding: 0;
  transition: background-color var(--dur) ease, border-color var(--dur) ease, color var(--dur) ease;
}
#view-projection .projection-col-tip:hover {
  background: rgba(226,232,240,.95); border-color: rgba(100,116,139,.6); color: #374151;
}
#view-projection #btnProjectionJumpToRetirement { white-space: nowrap; font-size: 13px; }


/* ──────────────────────────────────────────────
   4d · Strategy
   ────────────────────────────────────────────── */
/* View color, shell, muted, badge now standardised in Section 3 */
#view-strategy .strategy-intro-card { margin-bottom: 14px; }

/* Layout grid */
#view-strategy .strategy-head-row {
  display: grid;
  grid-template-columns: minmax(220px,1.2fr) minmax(200px,1fr) auto auto;
  align-items: end !important; gap: 8px !important;
}
#view-strategy .strategy-head-row .field { min-width: 0 !important; margin: 0 !important; gap: 3px; grid-column: auto !important; }
#view-strategy .strategy-targets-grid {
  display: grid;
  grid-template-columns: repeat(5,minmax(0,1fr));
  align-items: end !important; gap: 8px !important;
}
#view-strategy .strategy-targets-grid .field { min-width: 0 !important; margin: 0 !important; gap: 3px; grid-column: auto !important; }

/* Form elements */
#view-strategy .strategy-intro-card label { font-size: 10.5px; line-height: 1.2; }
#view-strategy .strategy-intro-card select,
#view-strategy .strategy-intro-card input {
  min-height: 36px; padding: 6px 9px;
  box-shadow: 0 1px 0 rgba(255,255,255,.7) inset;
}

/* Top cards */
#view-strategy .strategy-card-grid { gap: 16px; }
#view-strategy .strategy-top-card {
  background: linear-gradient(180deg, rgba(255,255,255,.98), rgba(246,248,251,.96)) !important;
  border: 1px solid rgba(15,23,42,.08); box-shadow: 0 14px 34px rgba(15,23,42,.08);
  border-radius: 24px; padding: 20px; min-height: 100%;
}
#view-strategy .strategy-top-card-label { color: #6b7280; letter-spacing: .08em; text-transform: uppercase; font-size: 11px; }
#view-strategy .strategy-top-card-title {
  font-size: 28px; line-height: 1.05; letter-spacing: -.04em;
  color: #111827; margin-bottom: 0;
}
#view-strategy .strategy-top-card-badges .badge { background: rgba(248,250,252,.95); border-color: rgba(15,23,42,.08); color: #475467; }
#view-strategy .strategy-top-card-summary { font-size: 14px; line-height: 1.55; color: #667085; max-width: 40ch; }
#view-strategy .strategy-top-card-note {
  padding: 10px 12px; border-radius: 14px;
  background: rgba(37,99,235,.06); color: #516176;
  border: 1px solid rgba(37,99,235,.10); line-height: 1.5;
}

/* KPIs */
#view-strategy .strategy-top-card-kpis { grid-template-columns: repeat(2,minmax(0,1fr)); gap: 10px; }
#view-strategy .strategy-kpi-item {
  padding: 14px; border-radius: 18px;
}
#view-strategy .strategy-kpi-item .label { display: block; color: #6b7280; font-size: 12px; line-height: 1.4; }
#view-strategy .strategy-kpi-item .value {
  display: block; margin-top: 8px; font-size: 24px;
  line-height: 1.1; letter-spacing: -.03em; color: #111827; font-weight: 700;
}

/* Detail grid / watchouts / explainers */
#view-strategy .strategy-detail-grid { gap: 16px; }
#view-strategy .strategy-context-callout,
#view-strategy .strategy-watchouts-shell {
  border-radius: 14px; padding: 12px;
}
#view-strategy .strategy-watchout-list { display: grid; gap: 8px; }
#view-strategy .strategy-explainer-shell {
  border-radius: 12px; padding: 10px;
}
#view-strategy .strategy-explainer-grid {
  display: grid; grid-template-columns: repeat(3,minmax(0,1fr)); gap: 8px;
}
#view-strategy .strategy-explainer-item {
  border-radius: 10px; padding: 8px;
  display: flex; flex-direction: column; gap: 2px;
}
#view-strategy .strategy-watchout-item {
  border-left: 4px solid rgba(100,116,139,.55) !important;
  border-radius: 12px; padding: 10px;
}
#view-strategy .strategy-watchout-medium { border-left-color: rgba(245,158,11,.7); }
#view-strategy .strategy-watchout-high { border-left-color: rgba(239,68,68,.7); background: rgba(254,242,242,.72); }

/* Comparison table */
#view-strategy .strategy-table-shell {
  border-radius: 20px;
}
#view-strategy .strategy-table-shell table {
  color: #1f2937; background: transparent; table-layout: auto; min-width: 1280px;
}
#view-strategy .strategy-table-shell th,
#view-strategy .strategy-table-shell td {
  padding: 10px; border-bottom: 1px solid rgba(15,23,42,.08);
  vertical-align: top; line-height: 1.3;
}
#view-strategy .strategy-table-shell th {
  color: #667085; font-size: 12px; text-transform: uppercase;
  letter-spacing: .04em; background: rgba(248,250,252,.88);
  position: sticky; top: 0; z-index: 1;
}
#view-strategy .strategy-table-shell tr:hover td { background: rgba(255,255,255,.55); }
#view-strategy .strategy-table-shell td:not(.strategy-cell-main):not(.strategy-cell-db) { white-space: nowrap; }
#view-strategy .strategy-cell-main { min-width: 250px; max-width: 300px; }
#view-strategy .strategy-cell-main strong { display: block; line-height: 1.25; margin-bottom: 2px; }
#view-strategy .strategy-table-summary {
  max-width: 32ch; display: -webkit-box; line-clamp: 3;
  -webkit-line-clamp: 3; -webkit-box-orient: vertical;
  overflow: hidden; line-height: 1.35; margin-top: 2px;
}
#view-strategy .strategy-cell-db { min-width: 150px; max-width: 190px; line-height: 1.3; }

/* Timeline */
#view-strategy .strategy-timeline-list { display: grid; gap: 12px; }
#view-strategy .strategy-timeline-card {
  border-radius: 20px;
  padding: 16px; margin-top: 0 !important; align-items: flex-start;
}
#view-strategy .strategy-timeline-dot {
  background: #3b82f6 !important;
  box-shadow: 0 0 0 6px rgba(59,130,246,.10); margin-top: 8px;
}
#view-strategy .strategy-timeline-age { font-size: 15px; color: #111827; letter-spacing: -.01em; }
#view-strategy .strategy-timeline-block {
  padding-top: 10px; border-top: 1px solid rgba(15,23,42,.06);
}
#view-strategy .strategy-timeline-block:first-of-type { border-top: 0; padding-top: 8px; }
#view-strategy .strategy-timeline-block strong { color: #111827; }


/* ──────────────────────────────────────────────
   4e · Bridge / Household / Scenarios / Help
   ────────────────────────────────────────────── */
/* View color, shell, muted, kpi now standardised in Section 3 */

#view-help .helpHero {
  border-color: rgba(37,99,235,.16);
  background: linear-gradient(135deg, rgba(59,130,246,.10), rgba(20,184,166,.09));
}


/* ──────────────────────────────────────────────
   4f · Stress
   ────────────────────────────────────────────── */
/* View color, shell, muted, h3/h4, tipCard, badge, forms,
   outcome cards, context notes, advanced details, panels/grids,
   status rows, preset/mode buttons now standardised in Section 3 */
#view-stress input[type='checkbox'] { accent-color: #2563eb; }
#view-stress .stress-chip:has(input:disabled) { opacity: .45; pointer-events: none; }

/* Grid margin */
#view-stress .stress-grid { margin-top: 14px; }

/* Preset & chip groups */
#view-stress .stress-presets { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 12px; }
#view-stress .stress-chip-groups { display: flex; flex-direction: column; gap: 10px; }
#view-stress .stress-chip-group { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
#view-stress .stress-chip-group-label {
  font-size: 11px; font-weight: 700; color: #94a3b8;
  text-transform: uppercase; letter-spacing: .05em; min-width: 72px;
}
#view-stress .stress-chip {
  display: flex; align-items: center; gap: 5px; cursor: pointer;
  border: 1px solid rgba(148,163,184,.3); border-radius: 999px;
  padding: 4px 10px; background: rgba(241,245,249,.9);
  color: #334155; font-size: 12px; font-weight: 500;
  transition: border-color var(--dur) ease, background-color var(--dur) ease;
}
#view-stress .stress-chip:hover { border-color: rgba(56,189,248,.5); background: rgba(224,242,254,.9); }
#view-stress .stress-chip:focus-within { box-shadow: var(--focus-ring); }
#view-stress .stress-chip:has(input:checked) {
  border-color: rgba(37,99,235,.35); background: rgba(239,246,255,.96); color: #1d4ed8;
}
#view-stress .stress-chip input { accent-color: #2563eb; margin: 0; }

/* Chart mode */
#view-stress .stress-chart-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
#view-stress .stress-chart-mode { display: flex; gap: 6px; }
#view-stress .stress-chart-mode-btn.active {
  background: rgba(37,99,235,.12) !important;
  border-color: rgba(37,99,235,.22) !important;
  color: #12335f !important;
  font-weight: 600;
}
#view-stress .stress-chart-legend { margin-top: 10px; display: flex; flex-wrap: wrap; gap: 8px; }
#view-stress .stress-legend-chip {
  display: inline-flex; align-items: center; gap: 7px;
  border: 1px solid rgba(148,163,184,.26); border-radius: 999px;
  background: rgba(255,255,255,.72); padding: 5px 9px;
  color: #334155; font-size: 11px;
  max-width: 280px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
#view-stress .stress-legend-swatch {
  width: 16px; height: 0; border-top-width: 3px;
  border-top-style: solid; border-radius: 2px; flex: 0 0 16px;
}
#view-stress .stress-legend-swatch.is-dashed { border-top-style: dashed; }

/* Ranking table */
#view-stress .stress-rank-table { width: 100%; border-collapse: collapse; font-size: 13px; }
#view-stress .stress-rank-table th {
  text-align: left; padding: 5px 8px; font-size: 11px; font-weight: 700;
  color: #94a3b8; text-transform: uppercase; letter-spacing: .04em;
  border-bottom: 1px solid rgba(15,23,42,.08);
}
#view-stress .stress-rank-table td {
  padding: 8px; border-bottom: 1px solid rgba(15,23,42,.05);
  color: #111827; vertical-align: middle;
}
#view-stress .stress-rank-table tr:last-child td { border-bottom: none; }
#view-stress .stress-rank-table tr.sev-fail td { background: rgba(254,242,242,.65); }
#view-stress .stress-rank-table .rank-label { font-weight: 600; color: #1f2937; }
#view-stress .stress-rank-table .rank-assum { font-size: 11px; color: #64748b; margin-top: 2px; }

/* Compound hero */
#view-stress .stress-compound-hero {
  border-width: 2px; border-radius: 14px;
  box-shadow: 0 8px 20px rgba(15,23,42,.08); margin-bottom: 10px;
}
#view-stress .stress-compound-hero strong { font-size: 15px; color: #111827; }


/* ──────────────────────────────────────────────
   4g · Monte Carlo
   ────────────────────────────────────────────── */
/* View color, shell, muted, h3/h4, tipCard, forms,
   outcome cards, context notes, advanced details, panels/grids,
   status rows now standardised in Section 3 */

#view-monte .risk-shell {
  background: linear-gradient(180deg, rgba(255,255,255,.97), rgba(248,250,252,.95));
  border-color: rgba(15,23,42,.10); color: #0f172a;
}
#view-monte .risk-row { background: rgba(255,255,255,.98); border-color: rgba(15,23,42,.10); color: #0f172a; }
#view-monte .risk-shell .small,
#view-monte .risk-shell .muted { color: #475569 !important; }

/* Grid margin */
#view-monte .monte-grid { margin-top: 8px; }


/* ──────────────────────────────────────────────
   4h · Report
   ────────────────────────────────────────────── */
#report { display: none; }
#report h1 { margin: 0 0 10px; }
#report .section { margin-top: 14px; border: 1px solid #ddd; border-radius: 12px; padding: 12px; }


/* ═══════════════════════════════════════════════════════════════
   5 · RESPONSIVE  —  Breakpoint overrides
   ═══════════════════════════════════════════════════════════════ */

@media (max-width: 1200px) {
  #view-overview .overview-summary-grid { grid-template-columns: repeat(2,minmax(0,1fr)); }
  #view-overview .overview-panel { grid-column: span 12; }
  #view-projection .projection-summary-grid { grid-template-columns: repeat(2,minmax(0,1fr)); }
  #view-projection .projection-summary-kpis { grid-template-columns: 1fr; }
  #view-projection .projection-row-detail-grid { grid-template-columns: repeat(2,minmax(0,1fr)); }
  #view-strategy .strategy-targets-grid { grid-template-columns: repeat(3,minmax(0,1fr)); }
}

@media (max-width: 980px) {
  .topbar h2 { font-size: 23px !important; }
  #view-overview .overview-summary-card .overview-summary-value {
    font-size: clamp(24px, 7.5vw, 30px) !important;
  }
  #view-strategy .strategy-top-card { grid-column: span 12 !important; }
  #view-strategy .strategy-head-row { grid-template-columns: 1fr 1fr; }
  #view-strategy .strategy-targets-grid { grid-template-columns: repeat(2,minmax(0,1fr)); }
  .strategy-col-4 { grid-column: span 12; }
  .strategy-mini-charts { grid-template-columns: 1fr; }
  .bridge-kpi { grid-column: span 6; }
  #view-projection #tblProjection { font-size: 12px; }
  #view-projection .projection-events-column { min-width: 240px; }
}

@media (max-width: 700px) {
  #view-inputs .tabs { padding: 8px; gap: 6px; }
  #view-inputs .tabs button { font-size: 12px; }
  #view-inputs .inputs-confidence-row .badge { width: 100%; }
  #view-inputs .validation-item { grid-template-columns: 1fr; }
  #view-inputs .validation-focus-btn { width: fit-content; }
  #view-inputs .household-grid .field { grid-column: span 12; }
  .risk-row { flex-direction: column; }
  .risk-row-kpis { justify-content: flex-start; }
  .risk-bucket-row { grid-template-columns: 1fr; }
  #view-stress .stress-panel { grid-column: span 12; }
  #view-stress .stress-rank-table th:nth-child(4),
  #view-stress .stress-rank-table th:nth-child(5),
  #view-stress .stress-rank-table td:nth-child(4),
  #view-stress .stress-rank-table td:nth-child(5) { display: none; }
  .bridge-kpi { grid-column: span 12; }
}

@media (max-width: 640px) {
  #view-overview .overview-summary-grid,
  #view-overview .overview-breakdown-grid { grid-template-columns: 1fr; }
  #view-projection .projection-summary-grid { grid-template-columns: 1fr; }
  #view-projection .projection-toolbar { flex-direction: column; }
  #view-projection .projection-mode-toggle { width: 100%; }
  #view-projection .projection-mode-toggle .btn { flex: 1; justify-content: center; }
  #view-projection .projection-row-detail-grid { grid-template-columns: 1fr; }
  #view-strategy .strategy-head-row,
  #view-strategy .strategy-targets-grid { grid-template-columns: 1fr; }
  #view-strategy .strategy-explainer-grid { grid-template-columns: 1fr; }
  #view-strategy .strategy-top-card-title { font-size: 24px; }
  #view-strategy .strategy-top-card-kpis { grid-template-columns: 1fr; }
  #view-strategy .strategy-kpi-item .value { font-size: 22px; }
  #view-strategy .strategy-table-shell th,
  #view-strategy .strategy-table-shell td { padding: 12px 10px; }
}

@media (max-width: 1100px) {
  .bridge-kpi { grid-column: span 6; }
}


/* ═══════════════════════════════════════════════════════════════
   6 · PRINT
   ═══════════════════════════════════════════════════════════════ */
@media print {
  body { background: white; color: black; }
  .sidebar, .actions, #toastWrap { display: none !important; }
  .content { max-width: none; }
  .card { box-shadow: none; background: white; border: 1px solid #ddd; }
  .svgwrap { border: 1px solid #ddd; background: white; }
  .svgwrap svg { min-width: 0; }
  .badge { border: 1px solid #999; background: #f5f5f5; }
  .badge.good, .badge.warn, .badge.bad { border-color: #999; }
  .badge .ico { background: #eaeaea; }
  #appMain { display: none !important; }
  #report { display: block !important; }
}

