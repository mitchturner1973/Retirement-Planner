                  <div class="repeater-empty-title">No lump sums yet</div>
                  <div class="repeater-empty-text">PCLS, UFPLS or taxable lump sums at specific ages.</div>
                  <button class="repeater-add-btn" id="btnAddLumpSum" type="button">+ Add DC lump sum</button>
                </div>
              </div>
            </div>
          </div>

          <!-- Other Income Panel -->
          <div id="subtab-you-other" class="subtab-panel" style="display:none">
            <div class="income-compact-card">
              <div class="income-compact-header">
                <div class="income-compact-icon"><svg viewBox="0 0 24 24"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg></div>
                <div class="income-compact-copy">
                  <h4>Other Taxable Income</h4>
                  <p>Rental income, dividends, freelance earnings or any other taxable income outside your salary and pensions.</p>
                </div>
              </div>
              <div class="form">
                <div class="field"><label>Other taxable income (&#163;/yr)</label><input type="number" id="in_otherIncome" min="0" step="100" /><div class="hint">This income is flat in today's money every year of the projection.</div></div>
              </div>
            </div>
          </div>
        </div>
        <!-- PARTNER TAB -->
        <div id="tab-partner" class="tab" style="display:none">
          <div class="income-compact-card" style="margin-bottom:24px">
            <div class="income-compact-header">
              <div class="income-compact-icon"><svg viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg></div>
              <div class="income-compact-copy">
                <h4>Household Mode</h4>
                <p>Choose single or joint to add your partner's details.</p>
              </div>
            </div>
            <div class="form">
              <div class="field">
                <label>Planner mode</label>
                <select id="in_householdMode">
                  <option value="single" selected>Single person</option>
                  <option value="joint">Joint household</option>
                </select>
              </div>
            </div>
          </div>

          <div id="spouseFields" style="display:none">
            <!-- Partner Personal Card -->
            <div class="income-personal-card open" id="incomePartnerPersonalCard" style="margin-bottom:24px">
              <div class="income-personal-header" data-toggle="incomePartnerPersonalCard">
                <div class="income-personal-icon"><svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg></div>
                <div class="income-personal-copy">
                  <h4>Partner Personal Details</h4>
                  <p>Date of birth, ages and timeline</p>
                </div>
                <div class="income-personal-badges">
                  <span class="income-personal-badge" id="incomePartnerAgeBadge">Age —</span>
                  <span class="income-personal-badge" id="incomePartnerRetireBadge">Retire —</span>
                </div>
                <button class="income-personal-toggle" type="button" aria-label="Toggle partner details"><svg viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"/></svg></button>
              </div>
              <div class="income-personal-body">
                <div class="form" style="display:grid;grid-template-columns:repeat(12,1fr);gap:16px;">
                  <div class="field" style="grid-column:span 3;display:flex;flex-direction:column;gap:6px;"><label>Date of birth</label><input type="date" id="in_spouseDob" /><div class="hint">Used to derive partner age.</div></div>
                  <div class="field" style="grid-column:span 3;display:flex;flex-direction:column;gap:6px;"><label>Values as at date</label><input type="date" id="in_spouseValuationDate" /><div class="hint">Reference date for partner balances.</div></div>
                  <div class="field" style="grid-column:span 3;display:flex;flex-direction:column;gap:6px;"><label>Current age</label><input type="number" id="in_spouseCurrentAge" min="18" max="90" /><span class="derived-chip">Auto-derived</span></div>
                  <div class="field" style="grid-column:span 3;display:flex;flex-direction:column;gap:6px;"><label>Months to birthday</label><input type="number" id="in_spouseFirstYearMonths" min="0.1" max="12" step="0.1" /><span class="derived-chip">Auto-derived</span></div>
                </div>
                <div class="form" style="display:grid;grid-template-columns:repeat(12,1fr);gap:16px;margin-top:16px;">
                  <div class="field" style="grid-column:span 6;display:flex;flex-direction:column;gap:6px;"><label>Retirement age</label><input type="number" id="in_spouseRetireAge" min="40" max="90" /></div>
                  <div class="field" style="grid-column:span 6;display:flex;flex-direction:column;gap:6px;"><label>State Pension age</label><input type="number" id="in_spouseStateAge" min="55" max="90" /></div>
                </div>
              </div>
            </div>

            <!-- Partner KPI Tabs -->
            <div class="income-kpi-tabs" id="subtabs-partner" role="tablist">
              <button class="income-kpi-tab active" data-subtab="partner-employment" type="button">
                <div class="income-kpi-icon">💼</div>
                <div class="income-kpi-label">Employment</div>
                <div class="income-kpi-value" id="partnerKpiSalary">£0</div>
              </button>
              <button class="income-kpi-tab" data-subtab="partner-pensions" type="button">
                <div class="income-kpi-icon">🏦</div>
                <div class="income-kpi-label">Pensions</div>
                <div class="income-kpi-value" id="partnerKpiPensions">£0</div>
              </button>
              <button class="income-kpi-tab" data-subtab="partner-income" type="button">
                <div class="income-kpi-icon">📊</div>
                <div class="income-kpi-label">Income</div>
                <div class="income-kpi-value" id="partnerKpiIncome">£0</div>
              </button>
            </div>

            <!-- Partner Employment Panel -->
            <div id="subtab-partner-employment" class="subtab-panel">
              <div class="income-accordion">
                <button class="income-accordion-btn active" type="button" data-accordion="p-emp-salary">
                  <div class="income-accordion-icon">💰</div>
