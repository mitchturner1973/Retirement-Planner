                  <div class="form">
                    <div class="field"><label>Salary (&#163;/yr)</label><input type="number" id="in_spouseSalary" min="0" step="100" /></div>
                    <div class="field"><label>Employee pension (% of salary)</label><input type="number" id="in_spouseEmpPct" step="0.1" /></div>
                    <div class="field"><label>Employer pension (% of salary)</label><input type="number" id="in_spouseErPct" step="0.1" /></div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Partner Pensions Panel -->
            <div id="subtab-partner-pensions" class="subtab-panel" style="display:none">
              <div class="income-accordion">
                <button class="income-accordion-btn active" type="button" data-accordion="p-pen-pot">
                  <div class="income-accordion-icon">💼</div>
                  <span class="income-accordion-title">Pension Pot</span>
                  <span class="income-accordion-summary" id="partnerAccordionSumPot">—</span>
                  <svg class="income-accordion-chevron" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"/></svg>
                </button>
                <div class="income-accordion-body active" id="accordion-p-pen-pot">
                  <div class="form">
                    <div class="field"><label>Pension pot (&#163;)</label><input type="number" id="in_spousePot" min="0" step="100" /></div>
                  </div>
                </div>
                <button class="income-accordion-btn" type="button" data-accordion="p-pen-dc">
                  <div class="income-accordion-icon">🏦</div>
                  <span class="income-accordion-title">Extra DC Pensions</span>
                  <span class="income-accordion-summary">None</span>
                  <svg class="income-accordion-chevron" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"/></svg>
                </button>
                <div class="income-accordion-body" id="accordion-p-pen-dc">
                  <div id="partnerDcPensionsSummary" class="inputs-repeater-summary muted small"></div>
                  <div id="partnerDcPensionsWrap"></div>
                  <div class="repeater-empty-state" id="partnerDcEmptyState">
                    <div class="repeater-empty-icon"><svg viewBox="0 0 24 24"><path d="M21 18v1c0 1.1-.9 2-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h14c1.1 0 2 .9 2 2v1h-9a2 2 0 00-2 2v8a2 2 0 002 2h9zm-9-2h10V8H12v8zm4-2.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg></div>
                    <div class="repeater-empty-title">No extra DC pensions yet</div>
                    <div class="repeater-empty-text">Partner's main pot is already included.</div>
                    <button class="repeater-add-btn" id="btnAddPartnerDc" type="button">+ Add DC pension</button>
                  </div>
                </div>
                <button class="income-accordion-btn" type="button" data-accordion="p-pen-db">
                  <div class="income-accordion-icon">🏛️</div>
                  <span class="income-accordion-title">DB Pensions</span>
                  <span class="income-accordion-summary">None</span>
                  <svg class="income-accordion-chevron" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"/></svg>
                </button>
                <div class="income-accordion-body" id="accordion-p-pen-db">
                  <div id="partnerDbPensionsSummary" class="inputs-repeater-summary muted small"></div>
                  <div id="partnerDbPensionsWrap"></div>
                  <div class="repeater-empty-state" id="partnerDbEmptyState">
                    <div class="repeater-empty-icon"><svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1.41 16.09V20h-2.67v-1.93c-1.71-.36-3.16-1.46-3.27-3.4h1.96c.1 1.05.82 1.87 2.65 1.87 1.96 0 2.4-.98 2.4-1.59 0-.83-.44-1.61-2.67-2.14-2.48-.6-4.18-1.62-4.18-3.67 0-1.72 1.39-2.84 3.11-3.21V4h2.67v1.95c1.86.45 2.79 1.86 2.85 3.39H14.3c-.05-1.11-.64-1.87-2.22-1.87-1.5 0-2.4.68-2.4 1.64 0 .84.65 1.39 2.67 1.94s4.18 1.36 4.18 3.85c0 1.89-1.44 2.98-3.12 3.19z"/></svg></div>
                    <div class="repeater-empty-title">No DB pensions yet</div>
                    <div class="repeater-empty-text">Partner's defined benefit pensions.</div>
                    <button class="repeater-add-btn" id="btnAddPartnerDb" type="button">+ Add DB pension</button>
                  </div>
                </div>
                <button class="income-accordion-btn" type="button" data-accordion="p-pen-contrib">
                  <div class="income-accordion-icon">➕</div>
                  <span class="income-accordion-title">Extra Contributions</span>
                  <span class="income-accordion-summary">None</span>
                  <svg class="income-accordion-chevron" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"/></svg>
                </button>
                <div class="income-accordion-body" id="accordion-p-pen-contrib">
