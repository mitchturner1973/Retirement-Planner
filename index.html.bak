<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Retirement Planner — Web Version</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="./styles/tw.css" />
    <link rel="stylesheet" href="./styles/main.css" />
</head>
<body class="coach-theme-ready bg-app text-text-1 antialiased">
<div id="toastWrap" aria-live="polite" aria-atomic="true"></div>
<div id="sideOverlay" aria-hidden="true"></div>

<!-- Report (print / save as PDF) -->
<section id="report" aria-label="Export report">
  <h1>Retirement Planner — Report</h1>
  <div class="small" id="reportMeta"></div>
  <div class="section">
    <h2 class="mb-2">Summary</h2>
    <div id="reportSummary"></div>
    <div class="mt-2.5" id="reportStatus"></div>
  </div>
  <div class="section">
    <h2 class="mb-2">Stress tests</h2>
    <div id="reportStress"></div>
    <div class="svgwrap mt-2.5"><div id="reportStressChart"></div></div>
  </div>
  <div class="section">
    <h2 class="mb-2">Bridge</h2>
    <div id="reportBridge"></div>
    <div class="svgwrap mt-2.5"><div id="reportBridgeChart"></div></div>
  </div>
  <div class="section">
    <h2 class="mb-2">Monte Carlo</h2>
    <div id="reportMonte"></div>
    <div class="svgwrap mt-2.5"><div id="reportMonteChart"></div></div>
  </div>
  <div class="section">
    <h2 class="mb-2">Assumptions & limitations</h2>
    <div id="reportAssumptions"></div>
  </div>
</section>

<div class="app" id="appMain">
  <aside class="sidebar" id="appSidebar">
    <div class="rail-head">
      <button class="rail-toggle" id="btnRailToggle" type="button" aria-label="Collapse sidebar" aria-pressed="false" title="Collapse sidebar">⇤</button>
    </div>

    <div class="brand">
      <div class="logo" aria-hidden="true"></div>
      <div class="brand-copy">
        <h1>Retirement Planner</h1>
        <p>Plan • stress-test • compare</p>
      </div>
    </div>

    <nav class="nav-panel" aria-label="Your finances">
      <div class="nav-panel-head">Your finances</div>
      <div class="nav-panel-body">
        <button class="nav-panel-item" data-view-nav data-view="wealth" data-default-hint="Snapshot">
          <span class="nav-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false"><path d="M4 10h3v7H4zm6.5 0h3v7h-3zM2 19h20v3H2zm15-9h3v7h-3zM12 1L2 6v2h20V6z"/></svg>
          </span>
          <span class="nav-copy">
            <span class="nav-label">Current Wealth</span>
            <span class="nav-hint" data-pill>Snapshot</span>
          </span>
        </button>

        <button class="nav-panel-item" data-view-nav data-view="inputs" data-default-hint="Setup">
          <span class="nav-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm0-4h-2V7h2v8z"/></svg>
          </span>
          <span class="nav-copy">
            <span class="nav-label">Income</span>
            <span class="nav-hint" data-pill>Setup</span>
          </span>
        </button>

        <button class="nav-panel-item" data-view-nav data-view="expenses" data-default-hint="New">
          <span class="nav-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false"><path d="M19.5 3.5L18 2l-1.5 1.5L15 2l-1.5 1.5L12 2l-1.5 1.5L9 2 7.5 3.5 6 2v14H3v3a3 3 0 003 3h12a3 3 0 003-3V2l-1.5 1.5zM19 19a1 1 0 01-2 0v-3H8V5h11v14zM9 7h6v2H9zm0 4h6v2H9z"/></svg>
          </span>
          <span class="nav-copy">
            <span class="nav-label">Expenses</span>
            <span class="nav-hint" data-pill>New</span>
          </span>
        </button>

        <button class="nav-panel-item" data-view-nav data-view="assumptions" data-default-hint="Global">
          <span class="nav-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false"><path d="M3 17v2h6v-2H3zM3 5v2h10V5H3zm10 16v-2h8v-2h-8v-2h-2v6h2zM7 9v2H3v2h4v2h2V9H7zm14 4v-2H11v2h10zm-6-4h2V7h4V5h-4V3h-2v6z"/></svg>
          </span>
          <span class="nav-copy">
            <span class="nav-label">Assumptions</span>
            <span class="nav-hint" data-pill>Global</span>
          </span>
        </button>
      </div>
    </nav>

    <div class="rail-quick rail-quick--cta" role="group" aria-label="Quick actions">
      <button class="btn rail-cta" id="navQuickRecalc" type="button">Recalculate</button>
    </div>
  </aside>

  <main class="content min-h-screen">
    <div class="topbar">
      <div class="topbar-leading">
        <button class="btn menuBtn" id="btnMenu" aria-label="Open menu" aria-controls="appSidebar" aria-expanded="false">☰</button>
        <div class="workspace-switcher">
          <div class="workspace-eyebrow">Planning workspace</div>
          <div class="workspace-pill-row">
            <button class="workspace-pill workspace-pill--primary" type="button">Base workspace ▾</button>
            <button class="workspace-pill" type="button" disabled>Scenario library ▾</button>
          </div>
          <div class="workspace-view-row">
            <span class="workspace-label">Current view</span>
            <span class="view-chip" id="viewTitle">Overview</span>
          </div>
        </div>
      </div>
      <div class="topbar-status">
        <span class="badge" id="freshnessBadge" aria-label="Last updated"><span class="ico">⟳</span><span id="freshnessText">Updated —</span></span>
        <div class="topbar-next">
          <span class="workspace-label">Next focus</span>
          <button class="link-btn" type="button" data-overview-nav="strategy" id="topbarNextAction">Review strategy actions</button>
        </div>
      </div>
      <div class="topbar-actions">
        <div class="topbar-quick-actions">
          <button class="btn topbar-quick-btn" id="btnSave" type="button" title="Export inputs (.json)">Export</button>
          <button class="btn topbar-quick-btn" id="btnLoad" type="button" title="Import inputs">Import</button>
          <button class="btn topbar-quick-btn" id="btnSaveScenario" type="button" title="Save scenario">Save scenario</button>
          <button class="btn topbar-quick-btn" id="btnExportReport" type="button" title="Export report (PDF)">Report</button>
          <button class="btn topbar-quick-btn" id="btnResetInputs" type="button" title="Reset inputs">Reset</button>
          <button class="btn topbar-quick-btn" id="btnActions" type="button">Actions ▾</button>
          <button class="btn topbar-quick-btn" type="button" onclick="window.print()">Print</button>
          <input type="file" id="fileLoad" accept="application/json" style="display:none" />
        </div>
        <button class="btn primary" id="btnRecalc">Recalculate</button>
      </div>
    </div>

    <nav class="primary-nav" aria-label="Plan views">
      <button class="active" data-view-nav data-view="overview">Overview</button>
      <button data-view-nav data-view="wealth">Wealth</button>
      <button data-view-nav data-view="inputs">Income</button>
      <button data-view-nav data-view="expenses">Expenses</button>
      <button data-view-nav data-view="projection">Projection</button>
      <button data-view-nav data-view="strategy">Strategy</button>
      <button data-view-nav data-view="bridge">Bridge</button>
      <button data-view-nav data-view="household">Household</button>
      <button data-view-nav data-view="stress">Stress Tests</button>
      <button data-view-nav data-view="monte">Monte Carlo</button>
      <button data-view-nav data-view="scenarios">Scenarios</button>
      <button data-view-nav data-view="help">Help</button>
    </nav>

    <!-- OVERVIEW -->
    <section class="view" id="view-overview">
      <div class="card overview-shell space-y-5">
        <div class="overview-eyebrow">MY CURRENT SITUATION</div>
        <h3>Dashboard</h3>
        <p class="overview-subtitle">Your retirement position at today’s values</p>
        <div class="tipGrid" data-tips="view-overview"><div class="tipCard"><div class="ticon">🎯</div><div><div class="ttitle">Where you stand now</div><div class="ttext">Use the headline cards and status badges first, then drill into watchouts and actions.</div></div></div><div class="tipCard"><div class="ticon">🧭</div><div><div class="ttitle">What to review next</div><div class="ttext">Use recommended next steps to jump straight to Strategy, Projection, Stress, Bridge or Monte.</div></div></div><div class="tipCard"><div class="ticon">🧠</div><div><div class="ttitle">Direction over precision</div><div class="ttext">Exact £ values are estimates. Focus on resilience if markets or sequencing turns unfavourable.</div></div></div></div>

        <div class="overview-summary-grid" id="overviewHeadlineCards"></div>

      

        <div class="overview-grid">
          <article class="overview-panel overview-panel--flush" id="forecastChartMount"></article>
          <article class="overview-panel">
            <h4>Retirement income composition</h4>
            <div class="overview-breakdown-grid" id="overviewIncomeBreakdown"></div>
          </article>
          <div class="overview-proof-row">
            <article class="overview-panel overview-panel--proof">
              <h4>Plan overview</h4>
              <div id="overviewPlanSummary"></div>
            </article>
            <article class="overview-panel overview-panel--proof">
              <h4>Early retirement bridge feasibility</h4>
              <div id="overviewBridgeFeasibility"></div>
            </article>
          </div>
          <article class="overview-panel overview-panel--wide">
            <div class="overview-watchouts" id="overviewWatchouts"></div>
          </article>
          <article class="overview-panel">
            <h4>What changed</h4>
            <div class="overview-compare-controls">
              <select id="overviewCompareSource">
                <option value="previous">Compare vs previous recalculation</option>
                <option value="scenario">Compare vs saved scenario</option>
              </select>
              <select id="overviewCompareScenario"></select>
            </div>
            <div id="overviewChanges"></div>
          </article>
          <article class="overview-panel">
            <h4>Recommended next steps</h4>
            <div class="overview-next-steps" id="overviewNextSteps"></div>
          </article>
          <article class="overview-panel overview-panel--wide">
            <div class="mentor-header">
              <div class="mentor-eyebrow">PLANNING MENTOR</div>
              <h4>Next Best Actions</h4>
              <p class="mentor-subtitle">Start here. These are the highest-priority changes the mentor found after ranking impact, confidence, and effort.</p>
            </div>
            <div id="actionPanel" class="muted"></div>
          </article>
        </div>
      </div>
    </section>

    <!-- CURRENT WEALTH -->
    <section class="view" id="view-wealth" style="display:none">
      <div class="card wealth-shell space-y-5">
        <div class="view-eyebrow">YOUR FINANCES</div>
        <h3>Current Wealth</h3>
        <p class="view-subtitle">Your financial position and input progress at a glance</p>
        <div class="tipGrid" data-tips="view-wealth"><div class="tipCard"><div class="ticon">💎</div><div><div class="ttitle">Your snapshot</div><div class="ttext">See your total pension wealth, income, and input completeness in one place.</div></div></div><div class="tipCard"><div class="ticon">✏️</div><div><div class="ttitle">Quick edits</div><div class="ttext">Click any card to jump straight to the relevant input section and make changes.</div></div></div><div class="tipCard"><div class="ticon">📊</div><div><div class="ttitle">Track progress</div><div class="ttext">Watch the progress bar fill as you complete your financial picture.</div></div></div></div>
        <div id="wealthHeadline"></div>
        <div class="wealth-grid" id="wealthGrid"></div>
      </div>
    </section>

    <!-- INPUTS -->
    <section class="view" id="view-inputs" style="display:none">
      <div class="card inputs-shell space-y-4">
        <div class="view-eyebrow">YOUR FINANCES</div>
        <h3>Income</h3>
        <p class="view-subtitle">Build your financial picture — the planner does the maths</p>
        <div class="tipGrid" data-tips="view-inputs"><div class="tipCard"><div class="ticon">✍️</div><div><div class="ttitle">Keep it realistic</div><div class="ttext">If unsure, use slightly conservative assumptions and compare scenarios rather than guessing perfectly.</div></div></div><div class="tipCard"><div class="ticon">🔁</div><div><div class="ttitle">Change one thing</div><div class="ttext">Adjust one input at a time so you can see what actually caused the change.</div></div></div><div class="tipCard"><div class="ticon">💾</div><div><div class="ttitle">Save a baseline</div><div class="ttext">Once inputs look sensible, save “Baseline”. Then duplicate for “Early”, “Lower spend”, “More contrib”.</div></div></div></div>
        
        <p class="muted mt-0">All inputs are in today's money. The model converts nominal return/growth into real rates automatically.</p>
        <div id="validationSummary" class="callout mb-3" style="display:none"></div>

        <div class="tabs" role="tablist">
          <button class="active" data-tab="you">You</button>
          <button data-tab="partner">Partner</button>
        </div>

    

        <!-- YOU TAB -->
        <div id="tab-you" class="tab">
          <!-- Personal Card — collapsible, always visible -->
          <div class="income-personal-card open" id="incomePersonalCard">
            <div class="income-personal-header" data-toggle="incomePersonalCard">
              <div class="income-personal-icon"><svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg></div>
              <div class="income-personal-copy">
                <h4>Personal Details</h4>
                <p>Date of birth, valuation date and key retirement ages</p>
              </div>
              <div class="income-personal-badges">
                <span class="income-personal-badge" id="incomePersonalAgeBadge">Age —</span>
                <span class="income-personal-badge" id="incomePersonalRetireBadge">Retire —</span>
              </div>
              <button class="income-personal-toggle" type="button" aria-label="Toggle personal details"><svg viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"/></svg></button>
            </div>
            <div class="income-personal-body">
              <div class="form" style="display:grid;grid-template-columns:repeat(12,1fr);gap:16px;">
                <div class="field" style="grid-column:span 3;display:flex;flex-direction:column;gap:6px;"><label>Date of birth</label><input type="date" id="in_dob" /><div class="hint">Used to derive current age.</div></div>
                <div class="field" style="grid-column:span 3;display:flex;flex-direction:column;gap:6px;"><label>Values as at date</label><input type="date" id="in_valuationDate" /><div class="hint">Reference date for balances.</div></div>
                <div class="field" style="grid-column:span 3;display:flex;flex-direction:column;gap:6px;"><label>Current age</label><input type="number" id="in_currentAge" min="18" max="90" /><span class="derived-chip">Auto-derived</span></div>
                <div class="field" style="grid-column:span 3;display:flex;flex-direction:column;gap:6px;"><label>Months to birthday</label><input type="number" id="in_firstYearMonths" min="0.1" max="12" step="0.1" /><span class="derived-chip">Auto-derived</span></div>
              </div>
              <div class="form" style="display:grid;grid-template-columns:repeat(12,1fr);gap:16px;margin-top:16px;">
                <div class="field" style="grid-column:span 4;display:flex;flex-direction:column;gap:6px;"><label>Retirement age</label><input type="number" id="in_retireAge" min="40" max="90" /></div>
                <div class="field" style="grid-column:span 4;display:flex;flex-direction:column;gap:6px;"><label>Early retirement age</label><input type="number" id="in_earlyAge" min="40" max="90" placeholder="Optional" /></div>
                <div class="field" style="grid-column:span 4;display:flex;flex-direction:column;gap:6px;"><label>State Pension age</label><input type="number" id="in_stateAge" min="55" max="90" /></div>
              </div>
            </div>
          </div>

          <!-- Income KPI Tabs -->
          <div class="income-kpi-tabs" id="subtabs-you" role="tablist">
            <button class="income-kpi-tab active" data-subtab="you-employment" type="button">
              <div class="income-kpi-icon">💼</div>
              <div class="income-kpi-label">Employment</div>
              <div class="income-kpi-value" id="incomeKpiSalary">£0</div>
            </button>
            <button class="income-kpi-tab" data-subtab="you-retirement" type="button">
              <div class="income-kpi-icon">🏖️</div>
              <div class="income-kpi-label">Retirement</div>
              <div class="income-kpi-value" id="incomeKpiRetirement">£0</div>
            </button>
            <button class="income-kpi-tab" data-subtab="you-pensions" type="button">
              <div class="income-kpi-icon">🏦</div>
              <div class="income-kpi-label">Pensions</div>
              <div class="income-kpi-value" id="incomeKpiPensions">£0</div>
            </button>
            <button class="income-kpi-tab" data-subtab="you-other" type="button">
              <div class="income-kpi-icon">📊</div>
              <div class="income-kpi-label">Other Income</div>
              <div class="income-kpi-value" id="incomeKpiOther">£0</div>
            </button>
          </div>

          <!-- Employment Panel -->
          <div id="subtab-you-employment" class="subtab-panel">
            <div class="income-panel-grid">
              <div class="income-panel-left">
                <div class="income-stat-row">
                  <div class="income-stat-card">
                    <div class="income-stat-label">Salary run-rate</div>
                    <div class="income-stat-value" id="earningsSalaryHeadline">£0</div>
                    <div class="income-stat-meta" id="earningsSalaryNote">Add salary to get started.</div>
                  </div>
                  <div class="income-stat-card">
                    <div class="income-stat-label">Pension saving</div>
                    <div class="income-stat-value" id="earningsContributionHeadline">£0</div>
                    <div class="income-stat-meta" id="earningsContributionNote">Employee + employer total 0%.</div>
                  </div>
                  <div class="income-stat-card">
                    <div class="income-stat-label">Buffer income</div>
                    <div class="income-stat-value" id="earningsBufferHeadline">£0</div>
                    <div class="income-stat-meta" id="earningsBufferNote">Other income + growth.</div>
                  </div>
                </div>
                <div class="income-accordion">
                  <button class="income-accordion-btn active" type="button" data-accordion="emp-salary">
                    <div class="income-accordion-icon">💰</div>
                    <span class="income-accordion-title">Salary Details</span>
                    <span class="income-accordion-summary" id="accordionSumSalary">—</span>
                    <svg class="income-accordion-chevron" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"/></svg>
                  </button>
                  <div class="income-accordion-body active" id="accordion-emp-salary">
                    <div class="form">
                      <div class="field"><label>Salary (&#163;/yr)</label><input type="number" id="in_salary" min="0" step="100" /></div>
                      <div class="field"><label>Salary growth (%/yr, nominal)</label><input type="number" id="in_salaryGrowth" step="0.1" /><div class="hint">Nominal pay growth for projections.</div></div>
                    </div>
                  </div>
                  <button class="income-accordion-btn" type="button" data-accordion="emp-contrib">
                    <div class="income-accordion-icon">🏗️</div>
                    <span class="income-accordion-title">Pension Contributions</span>
                    <span class="income-accordion-summary" id="accordionSumContrib">—</span>
                    <svg class="income-accordion-chevron" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"/></svg>
                  </button>
                  <div class="income-accordion-body" id="accordion-emp-contrib">
                    <div class="form">
                      <div class="field"><label>Employee pension (% of salary)</label><input type="number" id="in_empPct" step="0.1" /></div>
                      <div class="field"><label>Employer pension (% of salary)</label><input type="number" id="in_erPct" step="0.1" /></div>
                    </div>
                  </div>
                </div>
                <div class="income-earnings-actions" role="group">
                  <button type="button" class="income-earnings-btn" id="btnEarningsResume">Finish later</button>
                  <button type="button" class="income-earnings-btn income-earnings-btn--primary" id="btnEarningsCopyPartner">Copy to partner</button>
                  <button type="button" class="income-earnings-btn" id="btnEarningsScenario">Save scenario</button>
                </div>
              </div>
              <div class="income-panel-right">
                <aside class="inputs-coach-panel" aria-live="polite">
                  <div class="inputs-coach-eyebrow">Coach</div>
                  <h5>Next suggestion</h5>
                  <p id="earningsCoachTip">Add your salary so the planner can size contribution headroom.</p>
                  <ul class="inputs-coach-list">
                    <li><span id="earningsCoachDetail1">Employer match not captured.</span></li>
                    <li><span id="earningsCoachDetail2">Growth set to nominal rate.</span></li>
                  </ul>
                  <button type="button" class="inputs-coach-link" id="btnEarningsFocusContrib">Adjust employer match</button>
                </aside>
              </div>
            </div>
          </div>

          <!-- Retirement Panel -->
          <div id="subtab-you-retirement" class="subtab-panel" style="display:none">
            <div class="income-panel-grid">
              <div class="income-panel-left">
                <div class="income-stat-row">
                  <div class="income-stat-card">
                    <div class="income-stat-label">State Pension</div>
                    <div class="income-stat-value" id="incomeStatSP">£0/yr</div>
                  </div>
                  <div class="income-stat-card">
                    <div class="income-stat-label">Drawdown Rate</div>
                    <div class="income-stat-value" id="incomeStatDraw">0%</div>
                  </div>
                </div>
                <div class="income-accordion">
                  <button class="income-accordion-btn active" type="button" data-accordion="ret-sp">
                    <div class="income-accordion-icon">🏛️</div>
                    <span class="income-accordion-title">State Pension</span>
                    <span class="income-accordion-summary" id="accordionSumSP">—</span>
                    <svg class="income-accordion-chevron" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"/></svg>
                  </button>
                  <div class="income-accordion-body active" id="accordion-ret-sp">
                    <div class="form">
                      <div class="field"><label>State Pension (today's &#163;/yr)</label><input type="number" id="in_statePension" step="100" /></div>
                    </div>
                  </div>
                  <button class="income-accordion-btn" type="button" data-accordion="ret-drawdown">
                    <div class="income-accordion-icon">📉</div>
                    <span class="income-accordion-title">Drawdown Rules</span>
                    <span class="income-accordion-summary" id="accordionSumDraw">—</span>
                    <svg class="income-accordion-chevron" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"/></svg>
                  </button>
                  <div class="income-accordion-body" id="accordion-ret-drawdown">
                    <div class="form">
                      <div class="field"><label>Drawdown rate (% of pot/yr)</label><input type="number" id="in_draw" step="0.1" /></div>
                      <div class="field w12"><div class="hint">Recurring drawdown is regular annual withdrawals. One-off withdrawals go in <strong>Pensions &rarr; Lump Sums</strong>.</div></div>
                      <div class="field"><label>Tax&#8209;free cash per withdrawal (%)</label><input type="number" id="in_tflsPct" step="0.1" /></div>
                      <div class="field"><label>TFLS cap / LSA (&#163;)</label><input type="number" id="in_tflsCap" step="100" /></div>
                    </div>
                  </div>
                  <button class="income-accordion-btn" type="button" data-accordion="ret-tax">
                    <div class="income-accordion-icon">📋</div>
                    <span class="income-accordion-title">Tax Controls</span>
                    <span class="income-accordion-summary" id="accordionSumTax">UK 2024/25</span>
                    <svg class="income-accordion-chevron" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"/></svg>
                  </button>
                  <div class="income-accordion-body" id="accordion-ret-tax">
                    <div class="form">
                      <div class="field"><label>Personal Allowance (&#163;)</label><input type="number" id="in_allow" step="10" /></div>
                      <div class="field"><label>Basic rate tax (%)</label><input type="number" id="in_basicTax" step="0.1" /></div>
                      <div class="field"><label>Higher-rate tax (%)</label><input type="number" id="in_higherTax" step="0.1" /></div>
                      <div class="field"><label>Higher-rate threshold (&#163;)</label><input type="number" id="in_higherThreshold" step="100" /></div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="income-panel-right">
                <div class="inputs-coach-panel">
                  <div class="inputs-coach-eyebrow">Guide</div>
                  <h5>Retirement income</h5>
                  <p>State pension starts at your State Pension age. Drawdown applies as a percentage of your DC pot each year.</p>
                  <ul class="inputs-coach-list">
                    <li>TFLS (tax-free lump sum) is taken from each drawdown.</li>
                    <li>Tax controls use UK 2024/25 defaults.</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <!-- Pensions Panel -->
          <div id="subtab-you-pensions" class="subtab-panel" style="display:none">
            <div class="income-stat-row">
              <div class="income-stat-card">
                <div class="income-stat-label">Workplace Pot</div>
                <div class="income-stat-value" id="incomeStatPot">£0</div>
              </div>
              <div class="income-stat-card">
                <div class="income-stat-label">Extra DC Pots</div>
                <div class="income-stat-value" id="incomeStatDcExtra">0</div>
              </div>
              <div class="income-stat-card">
                <div class="income-stat-label">DB Income</div>
                <div class="income-stat-value" id="incomeStatDb">£0/yr</div>
              </div>
            </div>
            <div class="income-accordion">
              <button class="income-accordion-btn active" type="button" data-accordion="pen-workplace">
                <div class="income-accordion-icon">💼</div>
                <span class="income-accordion-title">Workplace DC Pension</span>
                <span class="income-accordion-summary" id="accordionSumPot">—</span>
                <svg class="income-accordion-chevron" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"/></svg>
              </button>
              <div class="income-accordion-body active" id="accordion-pen-workplace">
                <div class="form">
                  <div class="field"><label>Workplace DC pension pot (&#163;)</label><input type="number" id="in_pot" min="0" step="100" /></div>
                </div>
              </div>
              <button class="income-accordion-btn" type="button" data-accordion="pen-dc">
                <div class="income-accordion-icon">🏦</div>
                <span class="income-accordion-title">Extra DC Pensions</span>
                <span class="income-accordion-summary" id="accordionSumDc">None</span>
                <svg class="income-accordion-chevron" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"/></svg>
              </button>
              <div class="income-accordion-body" id="accordion-pen-dc">
                <div id="dcPensionsSummary" class="inputs-repeater-summary muted small"></div>
                <div id="dcPensionsWrap"></div>
                <div class="repeater-empty-state" id="dcEmptyState">
                  <div class="repeater-empty-icon"><svg viewBox="0 0 24 24"><path d="M21 18v1c0 1.1-.9 2-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h14c1.1 0 2 .9 2 2v1h-9a2 2 0 00-2 2v8a2 2 0 002 2h9zm-9-2h10V8H12v8zm4-2.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg></div>
                  <div class="repeater-empty-title">No extra DC pensions yet</div>
                  <div class="repeater-empty-text">Each pot can have its own fee and withdrawal priority.</div>
                  <button class="repeater-add-btn" id="btnAddDc" type="button">+ Add DC pension</button>
                </div>
              </div>
              <button class="income-accordion-btn" type="button" data-accordion="pen-db">
                <div class="income-accordion-icon">🏛️</div>
                <span class="income-accordion-title">DB Pensions</span>
                <span class="income-accordion-summary" id="accordionSumDbPen">None</span>
                <svg class="income-accordion-chevron" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"/></svg>
              </button>
              <div class="income-accordion-body" id="accordion-pen-db">
                <div id="dbPensionsSummary" class="inputs-repeater-summary muted small"></div>
                <div id="dbPensionsWrap"></div>
                <div class="repeater-empty-state" id="dbEmptyState">
                  <div class="repeater-empty-icon"><svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1.41 16.09V20h-2.67v-1.93c-1.71-.36-3.16-1.46-3.27-3.4h1.96c.1 1.05.82 1.87 2.65 1.87 1.96 0 2.4-.98 2.4-1.59 0-.83-.44-1.61-2.67-2.14-2.48-.6-4.18-1.62-4.18-3.67 0-1.72 1.39-2.84 3.11-3.21V4h2.67v1.95c1.86.45 2.79 1.86 2.85 3.39H14.3c-.05-1.11-.64-1.87-2.22-1.87-1.5 0-2.4.68-2.4 1.64 0 .84.65 1.39 2.67 1.94s4.18 1.36 4.18 3.85c0 1.89-1.44 2.98-3.12 3.19z"/></svg></div>
                  <div class="repeater-empty-title">No DB pensions yet</div>
                  <div class="repeater-empty-text">Final salary or career average income streams.</div>
                  <button class="repeater-add-btn" id="btnAddDb" type="button">+ Add DB pension</button>
                </div>
              </div>
              <button class="income-accordion-btn" type="button" data-accordion="pen-contrib">
                <div class="income-accordion-icon">➕</div>
                <span class="income-accordion-title">Extra Contributions</span>
                <span class="income-accordion-summary" id="accordionSumContribEvents">None</span>
                <svg class="income-accordion-chevron" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"/></svg>
              </button>
              <div class="income-accordion-body" id="accordion-pen-contrib">
                <div id="contribEventsSummary" class="inputs-repeater-summary muted small"></div>
                <div id="contribEventsWrap"></div>
                <div class="repeater-empty-state" id="contribEmptyState">
                  <div class="repeater-empty-icon"><svg viewBox="0 0 24 24"><path d="M13 7h-2v4H7v2h4v4h2v-4h4v-2h-4V7zm-1-5C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/></svg></div>
                  <div class="repeater-empty-title">No extra contributions yet</div>
                  <div class="repeater-empty-text">One-off top-ups, monthly boosts, and bonus-funded payments.</div>
                  <button class="repeater-add-btn" id="btnAddContrib" type="button">+ Add contribution</button>
                </div>
              </div>
              <button class="income-accordion-btn" type="button" data-accordion="pen-lump">
                <div class="income-accordion-icon">💎</div>
                <span class="income-accordion-title">Lump Sum Withdrawals</span>
                <span class="income-accordion-summary" id="accordionSumLumpEvents">None</span>
                <svg class="income-accordion-chevron" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"/></svg>
              </button>
              <div class="income-accordion-body" id="accordion-pen-lump">
                <div id="lumpSumEventsSummary" class="inputs-repeater-summary muted small"></div>
                <div id="lumpSumEventsWrap"></div>
