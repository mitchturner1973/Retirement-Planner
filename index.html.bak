                  <div id="partnerContribEventsWrap"></div>
                  <div class="repeater-empty-state" id="partnerContribEmptyState">
                    <div class="repeater-empty-icon"><svg viewBox="0 0 24 24"><path d="M13 7h-2v4H7v2h4v4h2v-4h4v-2h-4V7zm-1-5C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/></svg></div>
                    <div class="repeater-empty-title">No extra contributions yet</div>
                    <div class="repeater-empty-text">Partner contribution events.</div>
                    <button class="repeater-add-btn" id="btnAddPartnerContrib" type="button">+ Add contribution</button>
                  </div>
                </div>
                <button class="income-accordion-btn" type="button" data-accordion="p-pen-lump">
                  <div class="income-accordion-icon">💎</div>
                  <span class="income-accordion-title">Lump Sum Withdrawals</span>
                  <span class="income-accordion-summary">None</span>
                  <svg class="income-accordion-chevron" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"/></svg>
                </button>
                <div class="income-accordion-body" id="accordion-p-pen-lump">
                  <div id="partnerLumpSumEventsSummary" class="inputs-repeater-summary muted small"></div>
                  <div id="partnerLumpSumEventsWrap"></div>
                  <div class="repeater-empty-state" id="partnerLumpEmptyState">
                    <div class="repeater-empty-icon"><svg viewBox="0 0 24 24"><path d="M5 8h14V6H5v2zm0 0h14v2H5V8zm7 11l4-4h-3V9h-2v6H8l4 4z"/></svg></div>
                    <div class="repeater-empty-title">No lump sums yet</div>
                    <div class="repeater-empty-text">Partner's lump sum withdrawals.</div>
                    <button class="repeater-add-btn" id="btnAddPartnerLumpSum" type="button">+ Add DC lump sum</button>
                  </div>
                </div>
              </div>
            </div>

            <!-- Partner Income Panel -->
            <div id="subtab-partner-income" class="subtab-panel" style="display:none">
              <div class="income-compact-card">
                <div class="income-compact-header">
                  <div class="income-compact-icon"><svg viewBox="0 0 24 24"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg></div>
                  <div class="income-compact-copy">
                    <h4>Partner Income</h4>
                    <p>State pension and other taxable income for your partner.</p>
                  </div>
                </div>
                <div class="form">
                  <div class="field"><label>State Pension (&#163;/yr)</label><input type="number" id="in_spouseStatePension" step="100" /></div>
                  <div class="field"><label>Other taxable income (&#163;/yr)</label><input type="number" id="in_spouseOtherIncome" min="0" step="100" /></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- EXPENSES -->
    <section class="view" id="view-expenses" style="display:none">
      <div class="card expenses-shell space-y-4">
        <div class="view-eyebrow">YOUR FINANCES</div>
        <h3>Expenses</h3>
        <p class="view-subtitle">Track your spending to size your retirement income target</p>
        <div class="callout">
          <div>📊</div>
          <div>
            <div class="font-bold">Coming soon</div>
            <div class="muted small">Expense tracking will help you set realistic retirement income targets based on your actual spending patterns. For now, use the Strategy view to set your desired retirement income.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ASSUMPTIONS -->
    <section class="view" id="view-assumptions" style="display:none">
      <div class="card assumptions-shell space-y-4">
        <div class="view-eyebrow">YOUR FINANCES</div>
        <h3>Assumptions</h3>
        <p class="view-subtitle">Global inputs shared across both profiles</p>
        <p class="text-sm text-text-3">These settings power projections, strategy scoring, bridge and Monte Carlo. Leave defaults if unsure, or duplicate scenarios before experimenting.</p>
        <div class="form">
          <div class="field"><label>Investment return (nominal %/yr)</label><input type="number" id="in_return" step="0.1" /></div>
          <div class="field"><label>Inflation (%/yr)</label><input type="number" id="in_inflation" step="0.1" /></div>
          <div class="field"><label>Return volatility (%/yr) for Monte Carlo</label><input type="number" id="in_vol" step="0.1" /></div>
          <div class="field"><label>Projection end age</label><input type="number" id="in_endAge" min="70" max="110" /></div>
          <div class="field"><label>Fees &amp; charges (%/yr)</label><input type="number" id="in_feePct" step="0.01" min="0" /></div>
          <div class="field w12"><label>Notes</label><input type="text" id="in_notes" placeholder="Optional: scenario notes" /></div>
        </div>
      </div>
    </section>

    <!-- PROJECTION -->
    <section class="view" id="view-projection" style="display:none">
      <div class="card projection-shell space-y-4">
        <div class="view-eyebrow">MY FUTURE PLANS</div>
        <h3>Projection</h3>
        <p class="view-subtitle">Year-by-year forecast at today’s values</p>
        <div class="tipGrid" data-tips="view-projection"><div class="tipCard"><div class="ticon">📈</div><div><div class="ttitle">Average path only</div><div class="ttext">Projection is one smooth path. Real markets vary — that’s why Stress + Monte Carlo matter.</div></div></div><div class="tipCard"><div class="ticon">🧾</div><div><div class="ttitle">Know the phases</div><div class="ttext">Working years = salary+contrib. Retirement = withdrawals. State Pension starts at SP age.</div></div></div><div class="tipCard"><div class="ticon">🧊</div><div><div class="ttitle">Today’s money</div><div class="ttext">All values are inflation-adjusted. It’s buying power today, not future cash.</div></div></div></div>
        <div class="projection-summary-grid" id="projectionSummaryCards"></div>
        <div class="projection-toolbar">
          <div>
            <div class="projection-help-text" id="projectionHelpText"></div>
            <div class="projection-legend-row" id="projectionLegend"></div>
            <div class="projection-row-count muted" id="projectionRowCount"></div>
          </div>
          <div class="projection-controls-cluster">
            <div class="projection-mode-toggle" role="group" aria-label="Projection person" id="projectionPersonToggle" hidden>
              <button class="btn active" id="btnProjectionPerson_primary" type="button">You</button>
              <button class="btn" id="btnProjectionPerson_partner" type="button">Partner</button>
            </div>
            <div class="projection-mode-toggle" role="group" aria-label="Projection year range">
              <button class="btn active" id="btnProjectionRange_all" type="button">All years</button>
              <button class="btn" id="btnProjectionRange_retirement" type="button">Retirement onward</button>
              <button class="btn" id="btnProjectionRange_milestones" type="button">Milestones</button>
            </div>
            <div class="projection-mode-toggle" role="group" aria-label="Projection view mode">
              <button class="btn active" id="btnProjectionDetailed" type="button">Detailed</button>
              <button class="btn" id="btnProjectionCompact" type="button">Compact</button>
            </div>
            <button class="btn btn-outline" id="btnProjectionJumpToRetirement" type="button" title="Scroll to retirement year">⬇ Retirement</button>
          </div>
        </div>
        <div class="projection-table-shell mt-2.5 overflow-auto">
          <table id="tblProjection">
            <thead><tr>
              <th>Age</th>
              <th class="right">Salary</th>
              <th class="right">Contrib</th>
              <th class="right">Pot (start-year)</th>
              <th class="right">Pot (end-year)</th>
              <th class="right">Gross DC Withdrawal</th>
              <th class="right">Recurring DC Net Income</th>
              <th class="right">State Pension</th>
              <th class="right">DB income</th>
              <th class="right">One-off Lump Sums</th>
              <th class="right">Remaining TFLS / LSA</th>
              <th class="right">Recurring Total Net Income</th>
              <th class="right">Total Cash Received</th>
              <th>Notes</th>
            </tr></thead>
            <tbody></tbody>
          </table>
        </div>
        <div class="footer">All values are inflation-adjusted (today’s money). Tax is simplified; see Help.</div>
      </div>
    </section>

    <!-- BRIDGE -->
    <section class="view" id="view-bridge" style="display:none">
      <div class="card bridge-shell space-y-4">
        <div class="view-eyebrow">MY FUTURE PLANS</div>
        <h3>Early Retirement Bridge</h3>
        <p class="view-subtitle">Modelling the gap from early retirement to State Pension</p>
        <div class="tipGrid" data-tips="view-bridge"><div class="tipCard"><div class="ticon">🧱</div><div><div class="ttitle">Bridge is the gap</div><div class="ttext">If you retire before SP age, Bridge checks whether the pot can fund the gap safely.</div></div></div><div class="tipCard"><div class="ticon">🏁</div><div><div class="ttitle">Watch run‑out age</div><div class="ttext">If the bridge runs out early, it’s fragile. Check both baseline and lifestyle path if enabled.</div></div></div><div class="tipCard"><div class="ticon">🟣</div><div><div class="ttitle">Read the chart</div><div class="ttext">Markers show Early age, SP age, and any run‑out age. Purple line = maintain lifestyle.</div></div></div></div>
        <p class="text-sm text-text-3">This models an early retirement bridge period (early age → State Pension age). Net income figures are <strong>after tax</strong> and <strong>include State Pension once it starts</strong>.</p>

        <div class="view-subnav" role="tablist" data-subnav="bridge">
          <button class="active" data-subnav-target="results" type="button">Results</button>
          <button data-subnav-target="inputs" type="button">Bridge inputs</button>
        </div>

        <div class="view-subpanel" data-subnav="bridge" data-subnav-panel="results">
          <div class="kpi mt-3" id="bridgeKpis"></div>

          <div class="grid mt-4">
            <div class="card card-subtle col-span-12">
              <h3>Pot trajectory with bridge (today’s £)</h3>
              <div class="svgwrap"><svg id="chartBridge" width="980" height="270" role="img" aria-label="Bridge chart"></svg></div>
              <div class="footer">Markers: Early retirement, State Pension, and run‑out age (if any).</div>
            </div>
          </div>

          <div class="card card-subtle mt-3">
            <h3>Bridge years breakdown (today’s £)</h3>
            <div class="overflow-auto">
              <table id="tblBridge">
                <thead><tr>
                  <th>Age</th><th class="right">Gross withdrawal</th><th class="right">Net income</th><th class="right">Pot (start-year)</th><th class="right">Pot (end-year)</th><th>Note</th>
                </tr></thead>
                <tbody></tbody>
              </table>
            </div>
            <div class="footer">The last row includes the first year with State Pension (bridge end age).</div>
          </div>
        </div>

        <div class="view-subpanel" data-subnav="bridge" data-subnav-panel="inputs" hidden>
          <div class="form">
            <div class="field"><label>Early retirement age</label><input type="number" id="br_earlyAge" min="40" max="90" placeholder="e.g. 60" /></div>
            <div class="field"><label>Bridge input type</label>
              <select id="br_mode">
                <option value="net" selected>Net spend target (today’s £/yr)</option>
                <option value="gross">Gross pension withdrawal (today’s £/yr)</option>
              </select>
            </div>
            <div class="field"><label>Bridge amount (today’s £/yr)</label><input type="number" id="br_amount" step="100" placeholder="e.g. 25000" /></div>
            <div class="field"><label>Bridge ends at age</label><input type="number" id="br_endAge" min="55" max="90" /></div>
            <div class="field"><label>After-bridge drawdown rate (%/yr)</label><input type="number" id="br_postDraw" step="0.1" /></div>
            <div class="field"><label>Maintain lifestyle after bridge?</label>
              <select id="br_keepLifestyle">
                <option value="1" selected>Yes (target same net as bridge)</option>
                <option value="0">No (use drawdown % only)</option>
              </select>
            </div>
          </div>

          <div class="hr"></div>

          <div class="row gap-2 flex-wrap">
            <span class="badge"><span class="ico">🧯</span>Bridge stress overlays</span>
            <label class="badge cursor-pointer"><input type="checkbox" id="br_crashEarly" class="mr-1.5"/>Crash at early retirement</label>
            <label class="badge cursor-pointer"><input type="checkbox" id="br_crashState" class="mr-1.5"/>Crash at State Pension age</label>
            <label class="badge cursor-pointer"><input type="checkbox" id="br_badSeq" class="mr-1.5"/>Bad sequence from early retirement</label>
          </div>

          <div class="hr"></div>
        </div>
      </div>
    </section>


    <!-- STRATEGY -->
    <section class="view strategy-view" id="view-strategy" style="display:none">
      <div class="card strategy-intro-card space-y-4">
        <div class="view-eyebrow">MY FUTURE PLANS</div>
        <h3>Strategy</h3>
        <p class="view-subtitle">Compare withdrawal approaches and build your action plan</p>
        <p class="text-sm text-text-3">This view compares coded withdrawal strategies, scores them for tax, sustainability and balance, then turns the selected plan into a year-by-year action timeline.</p>

        <div class="view-subnav" role="tablist" data-subnav="strategy">
          <button class="active" data-subnav-target="overview" type="button">Recommendations</button>
          <button data-subnav-target="settings" type="button">Strategy inputs</button>
          <button data-subnav-target="tax" type="button">Tax optimisation</button>
        </div>

        <div class="view-subpanel" data-subnav="strategy" data-subnav-panel="overview">
          <p class="muted view-subpanel-hint">Use the Strategy inputs panel to adjust goals and constraints. Recommendations update automatically when you recalculate.</p>
          <div class="strategy-lab-shell">
            <aside class="strategy-lab-sidebar">
              <div class="strategy-lab-intro">
                <div class="strategy-lab-eyebrow">Strategy Lab</div>
                <h4>Browse withdrawal playbooks</h4>
                <p class="small muted">Compare focus areas (cash, tax, bridge) and pick one to drive your action plan.</p>
              </div>
              <div id="strategyLabList"></div>
            </aside>
            <div class="strategy-lab-main">
              <div id="strategyDetailWrap" class="strategy-detail-stack"></div>
            </div>
          </div>
        </div>

        <div class="view-subpanel" data-subnav="strategy" data-subnav-panel="tax" hidden>
          <div class="tax-shell">
            <div id="strategyTaxSummary"></div>
            <div class="tax-grid-2col">
              <section id="strategyTaxOrder" class="card"></section>
              <section id="strategyTaxFindings" class="card"></section>
            </div>
            <section id="strategyTaxComparisons" class="card"></section>
            <div class="tax-grid-2col">
              <section id="strategyTaxExplainer" class="card"></section>
              <section id="strategyTaxBands" class="card"></section>
            </div>
            <section id="strategyTaxActions" class="card"></section>
          </div>
        </div>

        <div class="view-subpanel" data-subnav="strategy" data-subnav-panel="settings" hidden>
          <div class="strat-inputs-shell">
            <!-- Card 1 — Strategy selection -->
            <div class="strat-inputs-card">
              <div class="strat-inputs-card-head">
                <span class="strat-inputs-card-icon">🎯</span>
                <div>
                  <h4>Strategy selection</h4>
                  <p class="small muted">Choose plan &amp; priority mode</p>
                </div>
              </div>
              <div class="strat-inputs-grid">
                <div class="field">
                  <label>Select strategy timeline</label>
                  <select id="strategySelect"></select>
                </div>
                <div class="field">
                  <label>Strategy priority</label>
                  <select id="in_strategyPriorityMode">
                    <option value="balanced">Balanced</option>
                    <option value="minimise-tax">Minimise tax</option>
                    <option value="maximise-stable-income">Maximise stable income</option>
                    <option value="preserve-flexibility">Preserve flexibility</option>
                    <option value="prioritise-guaranteed-income">Prioritise guaranteed income</option>
                  </select>
                </div>
              </div>
              <div class="strat-inputs-badges">
                <span class="strat-inputs-badge">🧭 Deterministic engine only</span>
                <span class="strat-inputs-badge">£ Strategies scored on tax, stability and remaining pot</span>
              </div>
            </div>

            <!-- Card 2 — Income targets -->
            <div class="strat-inputs-card">
              <div class="strat-inputs-card-head">
                <span class="strat-inputs-card-icon">💰</span>
                <div>
                  <h4>Income targets</h4>
                  <p class="small muted">Minimum floor &amp; comfortable target</p>
                </div>
              </div>
              <div class="strat-inputs-grid">
                <div class="field">
                  <label>Minimum desired net income (£/yr)</label>
                  <input type="number" id="in_minimumDesiredNetIncome" min="0" step="100" />
                </div>
                <div class="field">
                  <label>Target net income at retirement (£/yr)</label>
                  <input type="number" id="in_targetRetirementNetIncome" min="0" step="100" />
                </div>
                <div class="field">
                  <label>Minimum flexibility buffer at age 75 (£)</label>
                  <input type="number" id="in_minimumFlexibilityBufferAt75" min="0" step="1000" />
                </div>
              </div>
            </div>

            <!-- Card 3 — DB timing -->
            <div class="strat-inputs-card">
              <div class="strat-inputs-card-head">
                <span class="strat-inputs-card-icon">🏛️</span>
                <div>
                  <h4>DB pension timing</h4>
                  <p class="small muted">Early / deferred adjustment rates</p>
                </div>
              </div>
              <div class="strat-inputs-grid">
                <div class="field">
                  <label>DB early reduction (% per year before NPA)</label>
                  <input type="number" id="in_dbEarlyReductionPct" min="0" max="15" step="0.1" />
                </div>
                <div class="field">
                  <label>DB deferral increase (% per year after NPA)</label>
                  <input type="number" id="in_dbDeferralIncreasePct" min="0" max="15" step="0.1" />
                </div>
              </div>
            </div>

            <!-- Card 4 — Watchout thresholds -->
            <div class="strat-inputs-card">
              <div class="strat-inputs-card-head">
                <span class="strat-inputs-card-icon">⚠️</span>
                <div>
                  <h4>Watchout thresholds</h4>
                  <p class="small muted">Sensitivity triggers for alerts &amp; penalties</p>
                </div>
              </div>
              <div class="strat-inputs-grid">
                <div class="field">
                  <label>Income drop threshold (%)</label>
                  <input type="number" id="in_watchoutIncomeDropPct" min="1" max="100" step="1" />
                </div>
                <div class="field">
                  <label>Income drop threshold (£/yr)</label>
                  <input type="number" id="in_watchoutIncomeDropAbs" min="0" step="100" />
                </div>
                <div class="field">
                  <label>Low pot threshold (years of net)</label>
                  <input type="number" id="in_watchoutLateLifePotYears" min="1" max="20" step="0.5" />
                </div>
                <div class="field">
                  <label>High DC reliance threshold (%)</label>
                  <input type="number" id="in_watchoutDcReliancePct" min="1" max="100" step="1" />
                </div>
                <div class="field">
                  <label>Lump-sum watchout (% of net)</label>
                  <input type="number" id="in_watchoutLumpSumPctNet" min="1" max="300" step="1" />
                </div>
                <div class="field">
                  <label>Low remaining LSA threshold (£)</label>
                  <input type="number" id="in_watchoutLowLsa" min="0" step="1000" />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- HOUSEHOLD -->
    <section class="view" id="view-household" style="display:none">
      <div class="card household-view-shell space-y-4">
        <div class="view-eyebrow">MY CURRENT SITUATION</div>
        <h3>Household</h3>
        <p class="view-subtitle">Combined retirement view for you and your partner</p>
        <div class="tipGrid" data-tips="view-household"><div class="tipCard"><div class="ticon">🏠</div><div><div class="ttitle">Combined affordability</div><div class="ttext">This view answers the practical question: what does total household retirement income look like each month?</div></div></div><div class="tipCard"><div class="ticon">👤</div><div><div class="ttitle">See both shares</div><div class="ttext">You can compare your income versus your partner’s income at retirement and after each State Pension starts.</div></div></div><div class="tipCard"><div class="ticon">📅</div><div><div class="ttitle">Watch key ages</div><div class="ttext">The timeline highlights your retirement age, partner retirement age, and both State Pension start ages.</div></div></div></div>
        <div id="householdIntro" class="callout mt-3" style="display:none"></div>
        <div class="kpi mt-3" id="householdKpis"></div>
        <div class="grid mt-3">
          <div class="card card-subtle col-span-12">
            <h3>Combined monthly net retirement income</h3>
            <div class="svgwrap" style="position:relative"><svg id="chartHouseholdIncome" role="img" aria-label="Household monthly income chart"></svg></div>
            <div class="footer">Shows monthly net income after tax for the household and each person, using the planner assumptions.</div>
          </div>
        </div>
        <div class="grid mt-3">
          <div class="card card-subtle col-span-12">
            <h3>Combined household pot</h3>
            <div class="svgwrap" style="position:relative"><svg id="chartHouseholdPot" role="img" aria-label="Household pot chart"></svg></div>
            <div class="footer">This combines both pension pots. It helps show whether one pot is depleting much earlier than the other.</div>
          </div>
        </div>
        <div class="mt-2.5 overflow-auto">
          <table id="tblHousehold">
            <thead><tr>
              <th>Age</th>
              <th class="right">You (net/month)</th>
              <th class="right">Partner (net/month)</th>
              <th class="right">Household (net/month)</th>
              <th class="right">Combined pot</th>
              <th>Notes</th>
            </tr></thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- STRESS -->
    <section class="view" id="view-stress" style="display:none">
      <div class="card stress-shell space-y-4">
        <div class="view-eyebrow">VALIDATE</div>
        <h3>Stress Tests</h3>
        <p class="view-subtitle">Would your plan survive adverse market conditions?</p>
        <div class="tipGrid" data-tips="view-stress"><div class="tipCard"><div class="ticon">🧯</div><div><div class="ttitle">Gatekeeper test</div><div class="ttext">Stress tests ask: "Would I still be OK if the worst timing happens?"</div></div></div><div class="tipCard"><div class="ticon">⚠️</div><div><div class="ttitle">Baseline can mislead</div><div class="ttext">A plan can look fine in baseline but fail under a crash. Treat failures seriously.</div></div></div><div class="tipCard"><div class="ticon">✅</div><div><div class="ttitle">Green means resilient</div><div class="ttext">Passing stress suggests margin for error — the main goal of planning.</div></div></div></div>

        <div class="view-subnav" role="tablist" data-subnav="stress">
          <button class="active" data-subnav-target="results" type="button">Results</button>
          <button data-subnav-target="inputs" type="button">Stress inputs</button>
        </div>

        <div class="view-subpanel" data-subnav="stress" data-subnav-panel="results">
          <div class="stress-status-row">
            <span id="stressBadge"></span>
            <span id="stressBaseline"></span>
            <span id="stressCrash"></span>
            <span id="stressBadSeq"></span>
            <span id="stressCombinedBadge"></span>
            <span id="stressScenarioMeta"></span>
          </div>

          <div class="stress-grid">
            <article class="stress-panel stress-panel--wide">
              <div class="stress-chart-header">
                <h4 class="m-0">Pot trajectory under stress (today's £)</h4>
                <div class="stress-chart-mode">
                  <button class="stress-chart-mode-btn active" data-mode="core">Simple view</button>
                  <button class="stress-chart-mode-btn" data-mode="isolated">Show isolated</button>
                </div>
              </div>
              <div class="svgwrap"><svg id="chartStress" width="980" height="270" role="img" aria-label="Stress chart"></svg></div>
              <div id="stressChartLegend" class="stress-chart-legend"></div>
            </article>

            <article class="stress-panel">
              <h4>If one thing goes wrong (isolated)</h4>
              <div id="stressRankingExplain" class="stress-context-note"></div>
              <div id="stressScenarioSummary"><p class="muted small">Run a calculation to see scenario ranking.</p></div>
            </article>

            <article class="stress-panel">
              <h4>Will your plan last under stacked stress?</h4>
              <div id="stressDecisionSentence" class="stress-context-note"></div>
              <div id="stressCompoundSummary"><p class="muted small">Enable at least two scenarios to view compound knock-on effects.</p></div>
              <div id="stressWatchouts"><p class="muted small">Run a calculation to see stress watchouts.</p></div>
            </article>
          </div>
        </div>

        <div class="view-subpanel" data-subnav="stress" data-subnav-panel="inputs" hidden>
          <div class="stress-grid">
            <article class="stress-panel">
              <h4>Parameters</h4>
              <p class="muted small mb-2.5">Inputs for the Core crash and bad-sequence scenarios.</p>
              <div class="form">
                <div class="field"><label>Crash size at retirement (%)</label><input type="number" id="in_crashPct" step="1" /></div>
                <div class="field"><label>Bad-returns years (after retirement)</label><input type="number" id="in_badYears" step="1" /></div>
                <div class="field"><label>Bad-returns penalty (%/yr)</label><input type="number" id="in_badPenalty" step="0.5" /></div>
                <div class="field"><label>Success test age</label><input type="number" id="in_successAge" step="1" /></div>
                <div class="field w12"><label>"Enough" income floor after age 70 (today's £/yr)</label><input type="number" id="in_floor70" step="100" /></div>
                <div class="field w6"><label>Floor easing starts at age</label><input type="number" id="in_floorTaperStartAge" min="70" max="110" /><div class="hint">Floor only begins tapering after this age.</div></div>
                <div class="field w6"><label>Easing rate (% per year after start)</label><input type="number" id="in_floorTaperRatePct" step="0.1" min="0" max="10" /><div class="hint">How quickly the floor reduces once easing begins.</div></div>
                <div class="field w6"><label>Minimum floor (% of original)</label><input type="number" id="in_floorTaperMinPct" step="1" min="40" max="100" /><div class="hint">The lowest proportion the floor can reach (e.g. 65 = 65%).</div></div>
              </div>
            </article>

            <article class="stress-panel">
              <h4>Scenarios</h4>
              <div class="stress-presets">
                <button class="stress-preset-btn" data-preset="core">Core only</button>
                <button class="stress-preset-btn" data-preset="balanced">Balanced</button>
                <button class="stress-preset-btn" data-preset="all">All on</button>
                <button class="stress-preset-btn" data-preset="none">Clear all</button>
              </div>
              <div class="stress-chip-groups">
                <div class="stress-chip-group">
                  <span class="stress-chip-group-label">Core</span>
                  <label class="stress-chip"><input type="checkbox" id="in_stressScenarioCrash" checked />Crash at retirement</label>
                  <label class="stress-chip"><input type="checkbox" id="in_stressScenarioBadSeq" checked />Bad sequence</label>
                </div>
                <div class="stress-chip-group">
                  <span class="stress-chip-group-label">Macro</span>
                  <label class="stress-chip"><input type="checkbox" id="in_stressScenarioLowerReturns" checked />Lower returns</label>
                  <label class="stress-chip"><input type="checkbox" id="in_stressScenarioHigherInflation" checked />Higher inflation</label>
                </div>
                <div class="stress-chip-group">
                  <span class="stress-chip-group-label">Behaviour</span>
                  <label class="stress-chip"><input type="checkbox" id="in_stressScenarioEarlierRetire" checked />Earlier retirement</label>
                  <label class="stress-chip"><input type="checkbox" id="in_stressScenarioReducedContrib" checked />Reduced contributions</label>
                  <label class="stress-chip"><input type="checkbox" id="in_stressScenarioDrawdownPressure" checked />Drawdown pressure</label>
                </div>
                <div class="stress-chip-group">
                  <span class="stress-chip-group-label">Tail risk</span>
                  <label class="stress-chip"><input type="checkbox" id="in_stressScenarioLaterLifeFloor" checked />Later-life shortfall</label>
                  <label class="stress-chip" id="stress-chip-household"><input type="checkbox" id="in_stressScenarioHouseholdStrain" checked />Household strain</label>
                </div>
              </div>
            </article>
          </div>
        </div>
      </div>
    </section>

    <!-- MONTE -->
    <section class="view" id="view-monte" style="display:none">
      <div class="card monte-shell space-y-4">
        <div class="view-eyebrow">VALIDATE</div>
        <h3>Monte Carlo</h3>
        <p class="view-subtitle">Probability context across many simulated futures</p>
        <div class="tipGrid" data-tips="view-monte"><div class="tipCard"><div class="ticon">🎲</div><div><div class="ttitle">Many futures</div><div class="ttext">Monte Carlo runs your plan many times with random return paths to show uncertainty.</div></div></div><div class="tipCard"><div class="ticon">📊</div><div><div class="ttitle">Focus on 3 numbers</div><div class="ttext">Success %, Worst‑case depletion age, and P10 pot (downside buffer).</div></div></div><div class="tipCard"><div class="ticon">🟦</div><div><div class="ttitle">Read the bands</div><div class="ttext">White line is “typical”. Shaded ranges are realistic outcomes. Lower band above zero is strong.</div></div></div></div>
        <p class="text-sm text-text-3">Simulates many possible return paths using your average return and volatility. Use it for uncertainty context, not certainty.</p>

        <div class="view-subnav" role="tablist" data-subnav="monte">
          <button class="active" data-subnav-target="results" type="button">Results</button>
          <button data-subnav-target="inputs" type="button">Simulation inputs</button>
        </div>

        <div class="view-subpanel" data-subnav="monte" data-subnav-panel="results">
          <div class="monte-status-row">
            <span id="monteBadge"></span>
            <span id="mcDelta"></span>
            <span class="badge" id="mcProgressWrap" style="display:none"><span class="ico">⏳</span><span id="mcProgressText">Running…</span><span class="progress ml-2"><div id="mcProgressBar"></div></span></span>
            <button class="btn btn-outline" id="btnRunMonte" type="button">Run Monte</button>
          </div>

          <div class="monte-grid">
            <article class="monte-panel">
              <h4>What this means</h4>
              <div id="monteBottomLine" class="monte-context-note"></div>
              <div id="monteDecisionCards" class="monte-outcome-grid"></div>
              <details class="monte-advanced-details" open>
                <summary>Advanced diagnostics</summary>
                <div id="mcKpis" class="kpi mt-2"></div>
              </details>
            </article>

            <article class="monte-panel monte-panel--wide">
              <h4>Monte Carlo distribution (pot in today’s £)</h4>
              <div class="small muted mb-2">White line shows the typical path. Shaded range shows uncertainty.</div>
              <div class="svgwrap"><svg id="chartMC" width="980" height="280" role="img" aria-label="Monte Carlo chart"></svg></div>
            </article>

            <article class="monte-panel">
              <h4>Interpretation</h4>
              <div id="monteInterpretation"></div>
            </article>

            <article class="monte-panel">
              <h4>Actionable next steps</h4>
              <div id="monteActions"></div>
            </article>
          </div>
        </div>

        <div class="view-subpanel" data-subnav="monte" data-subnav-panel="inputs" hidden>
          <div class="monte-grid">
            <article class="monte-panel">
              <h4>Simulation controls</h4>
              <p class="muted small mb-2.5">Tweak settings, then rerun Monte Carlo to refresh the results.</p>
              <div class="form">
                <div class="field"><label>Simulations</label>
                  <select id="in_sims">
                    <option value="500">500</option>
                    <option value="1000" selected>1,000</option>
                    <option value="2000">2,000</option>
                    <option value="5000">5,000</option>
                  </select>
                </div>
                <div class="field"><label>Seed (optional)</label><input type="number" id="in_seed" placeholder="Random" /></div>
                <div class="field"><label>Ruin definition</label>
                  <select id="in_ruinDef">
                    <option value="0" selected>Pot hits £0 any time</option>
                    <option value="1">Pot < £10k (today’s £)</option>
                  </select>
                </div>
                <div class="field"><label>Show percentile bands</label>
                  <select id="in_bands">
                    <option value="1" selected>Yes</option>
                    <option value="0">No</option>
                  </select>
                </div>
              </div>
            </article>
          </div>
        </div>
      </div>
    </section>

    <!-- SCENARIOS -->
    <section class="view" id="view-scenarios" style="display:none">
      <div class="card scenarios-shell">
        <div class="view-eyebrow">MANAGE</div>
        <h3>Scenarios</h3>
        <p class="view-subtitle">Save, compare and contrast different planning assumptions</p>
        <div class="tipGrid" data-tips="view-scenarios"><div class="tipCard"><div class="ticon">🧩</div><div><div class="ttitle">Scenarios are snapshots</div><div class="ttext">A scenario is a saved set of inputs. Compare shows trade‑offs side‑by‑side.</div></div></div><div class="tipCard"><div class="ticon">🔎</div><div><div class="ttitle">Compare the right KPIs</div><div class="ttext">Look at run‑out age, pot left at end age, and MC success % (when run).</div></div></div><div class="tipCard"><div class="ticon">🏷️</div><div><div class="ttitle">Name clearly</div><div class="ttext">Use names like “Retire 60”, “+2% contrib”, “Lower spend” so comparisons are obvious.</div></div></div></div>
        <p class="text-sm text-text-3">Save named scenarios, then compare side-by-side (up to 3).</p>

        <div class="grid">
          <div class="card card-subtle col-span-5">
            <h3>Saved scenarios</h3>
            <div id="scenarioList" class="muted"></div>
            <div class="row mt-2.5">
              <button class="btn" id="btnNewScenario">Save current as new</button>
              <button class="btn" id="btnClearScenarios">Clear all</button>
            </div>
            <div class="footer">Scenarios are stored locally in your browser (offline).</div>
          </div>

          <div class="card card-subtle col-span-7">
            <h3>Compare</h3>
            <div class="muted small">Select up to 3 scenarios to compare.</div>
            <div id="scenarioCompare"></div>
            <div class="footer">Comparison includes readiness, pot at first draw age, pot at State Pension age (bridge baseline), run‑out ages, and Monte Carlo success.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- HELP -->
    <section class="view" id="view-help" style="display:none">
  <div class="card help-shell">
    <div class="view-eyebrow">MANAGE</div>
    <h3>Help</h3>
    <p class="view-subtitle">A gentle guide to retirement planning</p>

    <div class="helpHero mt-2.5">
      <div class="hicon">🧑‍🏫</div>
      <div>
        <h4>Welcome — you’re in the right place</h4>
        <p>If retirement planning feels confusing, that’s normal. This guide explains what the screens mean and how to make decisions without needing finance jargon.</p>
      </div>
    </div>

    <div class="hr"></div>

    <h3 class="mt-0">A simple learning path</h3>
    <div class="helpSteps">
      <div class="step"><div class="num">1</div><h5>Set a baseline</h5><p>Enter your best‑estimate inputs. Save this as “Baseline”.</p></div>
      <div class="step"><div class="num">2</div><h5>Check Stress tests</h5><p>If Stress fails, treat the plan as fragile even if the projection looks good.</p></div>
      <div class="step"><div class="num">3</div><h5>Early retirement? Use Bridge</h5><p>Bridge checks the gap to State Pension age and shows when the pot might run out.</p></div>
      <div class="step"><div class="num">4</div><h5>Add uncertainty with Monte Carlo</h5><p>Use Success %, Worst‑case depletion age, and P10 pot to understand downside risk.</p></div>
      <div class="step"><div class="num">5</div><h5>Compare scenarios</h5><p>Save 2–3 options and compare side‑by‑side. Prefer plans with margin for error.</p></div>
      <div class="step"><div class="num">6</div><h5>Improve with small levers</h5><p>Use Top 3 levers to move the weakest area from Amber/Red to Green.</p></div>
    </div>

    <div class="hr"></div>

    <div class="grid">
      <div class="card card-subtle col-span-6">
        <h3>What this tool is (and isn’t)</h3>
        <ul class="muted m-0">
          <li><strong>It is</strong> a planning tool that tests resilience (margin for error).</li>
          <li><strong>It isn’t</strong> a prediction of the future or financial advice.</li>
          <li>Values are shown in <strong>today’s money</strong> (inflation‑adjusted).</li>
          <li>Focus on <strong>robust plans</strong>, not perfect precision.</li>
        </ul>
      </div>
      <div class="card card-subtle col-span-6">
        <h3>The retirement problem (plain words)</h3>
        <ul class="muted m-0">
          <li><strong>Time</strong>: you may live longer than expected.</li>
          <li><strong>Bad luck</strong>: markets don’t rise smoothly.</li>
          <li><strong>Spending</strong>: drawing too much too early can cause trouble.</li>
          <li><strong>Sequence risk</strong>: poor returns early hurt the most.</li>
        </ul>
      </div>
    </div>

    <div class="hr"></div>

    <h3>Plain‑English explanations (tap to expand)</h3>
    <div class="grid">
      <div class="card card-soft col-span-12">
        <div class="grid m-0">
          <div class="card card-ghost col-span-6">
            <details class="helpAcc"><summary><span class="q">What is Monte Carlo?</span><span class="chev">▾</span></summary><div class="a">It runs your plan many times using random market return paths. It doesn’t predict the future — it shows how often your plan still works under uncertainty.</div></details>
            <details class="helpAcc mt-2.5"><summary><span class="q">What does “Success probability” mean?</span><span class="chev">▾</span></summary><div class="a">The % of simulated futures where your pot does not hit the “ruin” rule (usually £0) before the end age.</div></details>
            <details class="helpAcc mt-2.5"><summary><span class="q">What is P10 terminal pot?</span><span class="chev">▾</span></summary><div class="a">A pessimistic outcome. 9 out of 10 futures end with more pot than this. It’s a helpful downside buffer.</div></details>
          </div>
          <div class="card card-ghost col-span-6">
            <details class="helpAcc"><summary><span class="q">What are Stress tests?</span><span class="chev">▾</span></summary><div class="a">Specific “bad timing” checks like a crash at retirement or a run of poor early returns. Passing stress tests means resilience.</div></details>
            <details class="helpAcc mt-2.5"><summary><span class="q">What is the Bridge?</span><span class="chev">▾</span></summary><div class="a">If you retire before State Pension age, the Bridge is the gap you must fund yourself. The Bridge tab checks whether the pot can support that period.</div></details>
            <details class="helpAcc mt-2.5"><summary><span class="q">What does “today’s money” mean?</span><span class="chev">▾</span></summary><div class="a">Values are inflation‑adjusted. £30k means £30k of buying power today, not future cash. This makes scenarios easier to compare.</div></details>
          </div>
        </div>
      </div>
    </div>

    <div class="hr"></div>

    <h3>How to make decisions (simple rules)</h3>
    <div class="grid">
      <div class="card card-subtle col-span-4">
        <h3>Can I retire earlier?</h3>
        <p class="muted m-0">Check Bridge (gap holds), Stress (gatekeeper), and Monte Carlo (uncertainty).</p>
      </div>
      <div class="card card-subtle col-span-4">
        <h3>Can I spend more?</h3>
        <p class="muted m-0">Watch minimum pot after drawing starts and P10 pot. Avoid “knife‑edge” plans.</p>
      </div>
      <div class="card card-subtle col-span-4">
        <h3>Which scenario is better?</h3>
        <p class="muted m-0">Prefer margin for error: higher robustness even if income is slightly lower.</p>
      </div>
    </div>

    <div class="hr"></div>

    <h3>Common worries</h3>
    <details class="helpAcc"><summary><span class="q">“What if my assumptions are wrong?”</span><span class="chev">▾</span></summary><div class="a">That’s normal. Use Stress and Monte Carlo to see sensitivity. If tiny changes cause failure, the plan is fragile.</div></details>
    <details class="helpAcc mt-2.5"><summary><span class="q">“Why do tabs disagree?”</span><span class="chev">▾</span></summary><div class="a">Projection is an average path. Stress is specific bad timing. Monte Carlo is many random futures. Each answers a different question.</div></details>
    <details class="helpAcc mt-2.5"><summary><span class="q">“What should I do if I see Amber?”</span><span class="chev">▾</span></summary><div class="a">Amber means “watch this area”. Use Top 3 levers: adjust retirement age, contributions, or spending. Small changes often move Amber to Green.</div></details>

    <div class="footer">Teacher tip: Save 3 scenarios (Baseline, Early retirement, Lower spend). Compare them side‑by‑side to see trade‑offs clearly.</div>
  </div>
</section>

  
  <nav class="bottomNav" id="bottomNav" aria-label="Bottom navigation">
    <button data-view="overview" class="active" aria-label="Overview"><span class="bnav-ico">OV</span><span>Overview</span></button>
    <button data-view="wealth" aria-label="Wealth"><span class="bnav-ico">WL</span><span>Wealth</span></button>
    <button data-view="inputs" aria-label="Income"><span class="bnav-ico">IN</span><span>Income</span></button>
    <button data-view="expenses" aria-label="Expenses"><span class="bnav-ico">EX</span><span>Expenses</span></button>
    <button data-view="assumptions" aria-label="Assumptions"><span class="bnav-ico">AS</span><span>Assumptions</span></button>
    <button data-view="projection" aria-label="Projection"><span class="bnav-ico">PR</span><span>Projection</span></button>
    <button data-view="strategy" aria-label="Strategy"><span class="bnav-ico">ST</span><span>Strategy</span></button>
    <button data-view="bridge" aria-label="Bridge"><span class="bnav-ico">BR</span><span>Bridge</span></button>
    <button data-view="household" aria-label="Household"><span class="bnav-ico">HH</span><span>Household</span></button>
    <button data-view="stress" aria-label="Stress Tests"><span class="bnav-ico">RS</span><span>Stress Tests</span></button>
    <button data-view="monte" aria-label="Monte Carlo"><span class="bnav-ico">MC</span><span>Monte Carlo</span></button>
    <button data-view="scenarios" aria-label="Scenarios"><span class="bnav-ico">SC</span><span>Scenarios</span></button>
    <button data-view="help" aria-label="Help"><span class="bnav-ico">HP</span><span>Help</span></button>
  </nav>
</main>
</div>


  <script type="module" src="./src/app.js"></script>

<div class="sheet" id="actionSheet" aria-hidden="true" role="dialog" aria-label="Actions">
  <div class="sheetPanel" role="document">
    <div class="sheetHeader"><div class="sheetTitle">Quick actions</div>
      <button class="btn" id="btnSheetClose" type="button">Close ✕</button></div>
    <div class="sheetGrid">
      <button class="btn" data-act="save">Export inputs</button>
      <button class="btn" data-act="load">Import inputs</button>
      <button class="btn" data-act="reset">Reset inputs</button>
      <button class="btn" data-act="saveScenario">Save scenario</button>
      <button class="btn" data-act="report">Export report</button>
      <button class="btn primary" data-act="recalc">Recalculate</button>
      <button class="btn" data-act="print">Print</button>
    </div>
  </div>
</div>

<div class="sheet" id="cmdPalette" aria-hidden="true" role="dialog" aria-label="Command palette">
  <div class="sheetPanel cmdPanel" role="document">
    <div class="sheetHeader"><div class="sheetTitle">Quick command</div>
      <button class="btn" id="btnCmdClose" type="button">Close ✕</button></div>
    <input id="cmdInput" class="cmdInput" type="text" placeholder="Jump to a section or run an action (Cmd/Ctrl+K)" />
    <div id="cmdList" class="cmdList"></div>
  </div>
</div>
</body>

</html>
